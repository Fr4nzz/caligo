---
import { pick, type Person } from '../data/initiative';
import type { Locale } from '../i18n';
import CardIcon from './CardIcon.astro';

interface Props {
  readonly person: Person;
  readonly locale: Locale;
}

const { person, locale } = Astro.props;
const regionalTiesLabel = locale === 'en' ? 'Regional ties' : 'Vínculos regionales';
---

<article class="person-card">
  <div class="person-heading">
    <strong class="person-name">{person.name}</strong>
    <CardIcon name="person" />
  </div>
  <p class="person-role">{pick(person.role, locale)}</p>
  <p class="person-bio">{pick(person.bio, locale)}</p>
  <p class="person-affil mono">{person.affiliation}</p>
  <p class="person-region mono">
    <span>{regionalTiesLabel}:</span> {pick(person.regionalTies, locale)}
  </p>
  <a
    class="person-source mono"
    href={person.source.href}
    target="_blank"
    rel="noopener noreferrer external"
  >
    {pick(person.source.label, locale)} <span aria-hidden="true">↗</span>
  </a>
</article>

<style>
  .person-card {
    padding: var(--space-m);
    background: linear-gradient(145deg, var(--bg-panel), var(--bg-inset));
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .person-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-s);
    margin-bottom: 0.15rem;
  }
  .person-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    color: var(--text-strong);
    letter-spacing: -0.008em;
    line-height: 1.2;
  }
  .person-role {
    margin: 0;
    font-size: var(--step-0);
    color: var(--text);
    line-height: 1.4;
  }
  .person-bio {
    margin: 0.15rem 0 var(--space-xs);
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.55;
  }
  .person-affil {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text);
    letter-spacing: 0.01em;
    line-height: 1.45;
  }
  .person-region {
    margin: 0;
    font-size: var(--step--2);
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .person-region span {
    color: var(--text-muted);
  }
  .person-source {
    align-self: flex-start;
    margin-top: auto;
    padding-top: var(--space-xs);
    color: var(--accent);
    font-size: var(--step--2);
    letter-spacing: 0.02em;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 35%, transparent);
    text-underline-offset: 0.18em;
  }
  .person-source:hover {
    color: var(--accent-strong);
    text-decoration-color: currentColor;
  }
  .person-source:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
