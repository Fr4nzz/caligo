---
import { PRINCIPLES, pick } from '../data/initiative';
import type { Locale } from '../i18n';
import CardIcon, { type CardIconName } from './CardIcon.astro';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const principleIcons: readonly CardIconName[] = [
  'leadership',
  'taxonomy',
  'inclusive',
  'open',
  'practical',
  'rights',
  'community',
  'culture',
];
---

<ul class="principle-grid" role="list">
  {PRINCIPLES.map((principle, index) => (
    <li class="principle-card" data-lift>
      <div class="principle-heading">
        <CardIcon name={principleIcons[index] ?? 'project'} />
        <h3 class="principle-title">{pick(principle.title, locale)}</h3>
      </div>
      <p class="principle-body">{pick(principle.body, locale)}</p>
    </li>
  ))}
</ul>

<style>
  .principle-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-m);
    grid-template-columns: 1fr;
  }
  @media (min-width: 40rem) {
    .principle-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 72rem) {
    .principle-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .principle-card {
    padding: var(--space-m);
    background: linear-gradient(145deg, var(--bg-panel), var(--bg-inset));
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
  }
  .principle-heading {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: var(--space-s);
    margin-bottom: var(--space-s);
  }
  .principle-title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 620;
    color: var(--text-strong);
    letter-spacing: -0.006em;
    line-height: 1.25;
  }
  .principle-body {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.55;
  }
</style>
