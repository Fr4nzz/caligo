---
/**
 * HomePage — compact six-module persuasive path.
 *
 * Six modules in order:
 *   H1  Cinematic hero (full-bleed photo + overlay copy).
 *   H2  Why Caligo — four principles (h.pillars).
 *   H3  From organism to genome — six-step journey with per-step media.
 *   H4  Three questions worth following — compact teaser links to /science#.
 *   H5  Four proposed pilots — 2×2 compact cards with MediaCandidateViewer.
 *   H6  Participate + brand close — email CTA + namesake sentence → /caligo/.
 *
 * SectionRail is deliberately not used here — the cinematic hero must stay
 * above the fold. Stable section IDs (overview, snapshot,
 * from-organism-to-genome, questions, proposed-pilots, discover-caligo, plus
 * the #h1..#h6 shim anchors) are preserved for language-position
 * preservation, Back/Forward restoration and direct hash navigation.
 */
import Base from '../../layouts/Base.astro';
import HeroMedia from '../HeroMedia.astro';
import MediaCandidateViewer from '../MediaCandidateViewer.astro';
import Icon from '../Icon.astro';
import JoinCTA from '../JoinCTA.astro';
import PrincipleGrid from '../PrincipleGrid.astro';
import StatBar from '../StatBar.astro';
import SourceList from '../SourceList.astro';
import { getDict, localePath, type Locale } from '../../i18n';
import { PILOTS, PUBLIC_STATUS_LABELS, getMedia } from '../../data/records';
import { PARTICIPANTS, PROJECTS, facilityStats } from '../../data/initiative';

const journeyModuleIds = [
  'journey-1-organism',
  'journey-2-provenance',
  'journey-3-voucher',
  'journey-4-sequence',
  'journey-5-assemble',
  'journey-6-deposit',
] as const;

/**
 * Science-page anchor IDs for the six question teaser links, in the same
 * order as `t.science.questions[]` (single source of truth). Home renders
 * concise question hooks; the full four-layer answer lives on Science.
 * These slugs must match `sciQuestionAnchors` in SciencePage.astro.
 */
const questionAnchors = [
  'chromosomes',
  'gene-flow',
  'species-boundaries',
  'connectivity',
  'seasonal-movement',
  'biodiversity-reuse',
] as const;

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);
const h = t.home;
const base = import.meta.env.BASE_URL;

const heroMedia = getMedia('hero-caligo-tambopata');
if (!heroMedia) {
  throw new Error("HomePage: missing 'hero-caligo-tambopata' media record.");
}

const desktopSrcset = [
  { width: 800,  height: 451,  path: `${base}media/hero/caligo-tambopata-800w.jpg` },
  { width: 1200, height: 677,  path: `${base}media/hero/caligo-tambopata-1200w.jpg` },
  { width: 1600, height: 902,  path: `${base}media/hero/caligo-tambopata-1600w.jpg` },
  { width: 2400, height: 1354, path: `${base}media/hero/caligo-tambopata-2400w.jpg` },
] as const;
const mobileSrcset = [
  { width: 480, height: 514, path: `${base}media/hero/caligo-tambopata-portrait-480w.jpg` },
  { width: 800, height: 856, path: `${base}media/hero/caligo-tambopata-portrait-800w.jpg` },
] as const;

const publishedPilots = PILOTS.filter((p) => p.publish);

const { facilities, countries } = facilityStats();
const homeMetrics = [
  { kind: 'participants', value: PARTICIPANTS.value, label: h.stats.participants, asOf: h.stats.asOf },
  { kind: 'facilities', value: facilities, label: h.stats.facilities },
  { kind: 'countries', value: countries, label: h.stats.countries },
  { kind: 'pilots', value: PROJECTS.length, label: h.stats.pilots },
] as const;
---

<Base locale={locale} title={h.metaTitle} description={h.metaDescription} page="/">

  <!-- ====================== H1 — Cinematic hero ====================== -->
  <section id="overview" class="hero-cinematic" aria-labelledby="hero-title">
    <span id="h1" hidden aria-hidden="true" data-legacy-anchor="h1" />
    <div class="hero-media-frame">
      <HeroMedia
        mediaId="hero-caligo-tambopata"
        locale={locale}
        kind="photo"
        desktopSrcset={desktopSrcset}
        mobileSrcset={mobileSrcset}
        hideCaption
      />
    </div>

    <div class="hero-overlay">
      <div class="container-wide hero-overlay-inner">
        <div class="hero-copy">
          <p class="hero-eyebrow mono">{h.hero.kicker}</p>
          <h1 id="hero-title" class="hero-title">{h.hero.title}</h1>
          <p class="hero-tagline">{h.hero.body}</p>
          <div class="hero-actions">
            <a class="btn hero-btn-primary" href={localePath(locale, '/projects')}>
              {t.cta.seeProposedPilots}<Icon name="arrow-right" />
            </a>
            <a class="btn hero-btn-ghost" href={localePath(locale, '/science')}>
              {t.cta.exploreScience}
            </a>
          </div>
        </div>
      </div>
    </div>

    <p class="hero-attribution mono">
      {heroMedia.credit[locale]}
      {' '}
      <a href={heroMedia.licenceUrl} rel="license external noopener">{heroMedia.licence}</a>
    </p>
  </section>

  <!-- ==================== STAT BAR — network metrics ==================== -->
  <section class="section stat-bar-section">
    <div class="container-wide">
      <StatBar metrics={homeMetrics} variant="community-cards" />
    </div>
  </section>

  <!-- ====================== H2 — Why Caligo (four principles) ====================== -->
  <section id="snapshot" class="section" aria-labelledby="h2-title">
    <span id="h2" hidden aria-hidden="true" data-legacy-anchor="h2" />
    <div class="container-wide">
      <p class="section-eyebrow mono">{h.pillars.eyebrow}</p>
      <h2 id="h2-title">{h.pillars.title}</h2>
      <PrincipleGrid locale={locale}/>
    </div>
  </section>

  <!-- ====================== H3 — From organism to genome (six-step journey) ====================== -->
  <section id="from-organism-to-genome" class="section section--panel" aria-labelledby="h3-title">
    <span id="h3" hidden aria-hidden="true" data-legacy-anchor="h3" />
    <div class="container-wide">
      <h2 id="h3-title">{h.journey.heading}</h2>
      <p class="lead journey-intro">{h.journey.intro}</p>
      <ol class="journey-steps journey-vertical">
        {
          h.journey.steps.map((step, i) => (
            <li class="journey-step" id={`step-${i + 1}`}>
              <div class="journey-copy">
                <p class="journey-step-index mono" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </p>
                <h3 class="journey-step-title">{step.title}</h3>
                <p class="journey-step-body">{step.body}</p>
              </div>
              <div class="journey-media">
                <MediaCandidateViewer
                  moduleId={journeyModuleIds[i]}
                  locale={locale}
                  aspectRatio="16 / 9"
                />
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ====================== H4 — Six questions worth following ======================
       Home renders concise hooks (question heading only). The full four-layer
       answer + evidence + sources lives on the Science page. We iterate
       `t.science.questions` directly so Home and Science stay in lockstep by
       construction: no duplicated question copy, no drift in count.
  -->
  <section id="questions" class="section" aria-labelledby="h4-title">
    <span id="h4" hidden aria-hidden="true" data-legacy-anchor="h4" />
    <div class="container-wide">
      <h2 id="h4-title">{h.questions.heading}</h2>
      <p class="lead">{h.questions.intro}</p>
      <ol class="question-teasers" role="list">
        {t.science.questions.map((q, i) => (
          <li class="question-teaser">
            <a
              class="question-teaser-link"
              href={`${localePath(locale, '/science')}#${questionAnchors[i] ?? ''}`}
            >
              <span class="question-teaser-index mono" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="question-teaser-text">{q.heading}</span>
              <span class="question-teaser-cta mono">{t.common.exploreQuestion ?? (locale === 'es' ? 'Explora esta pregunta' : 'Explore this question')}</span>
              <Icon name="arrow-right" />
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ====================== H5 — Four proposed pilots (2×2 compact cards) ====================== -->
  <section id="proposed-pilots" class="section section--panel" aria-labelledby="h5-title">
    <span id="h5" hidden aria-hidden="true" data-legacy-anchor="h5" />
    <div class="container-wide">
      <h2 id="h5-title">{h.pilotsTeaser.heading}</h2>
      <p class="lead">{h.pilotsTeaser.intro}</p>

      <!--
        v7.4 concision: Home pilot cards are HOOKS, not summaries. Per-card
        content is index + status + heading + taxon + a single explicit
        "Explore this pilot →" affordance that deep-links to the pilot's
        section on the Pilots page. The full published context, evidence,
        methods, limits, sources and figures live on /projects — never on
        Home. This mirrors the H4 pattern (heading-only questions that link
        into Science) and cuts Home mobile card height ~35–40%.
      -->
      <ol class="pilot-cards" aria-label={h.pilotsTeaser.heading}>
        {publishedPilots.map((pilot, i) => (
          <li class="pilot-card" id={`preview-${pilot.slug}`}>
            <div class="pilot-card-media">
              <MediaCandidateViewer
                moduleId={pilot.id}
                locale={locale}
                aspectRatio="4 / 3"
              />
            </div>
            <div class="pilot-card-content">
              <div class="pilot-card-meta mono">
                <span class="pilot-card-index" aria-hidden="true">P{i + 1}</span>
                <span class="pilot-card-status">
                  {PUBLIC_STATUS_LABELS[pilot.status][locale]}
                </span>
              </div>
              <h3 class="pilot-card-heading">
                <a
                  class="pilot-card-heading-link"
                  href={`${localePath(locale, '/projects')}#${pilot.slug}`}
                >
                  {pilot.heading[locale]}
                </a>
              </h3>
              {pilot.taxon && (
                <p class="pilot-card-taxon mono"><em>{pilot.taxon}</em></p>
              )}
              <p class="pilot-card-cta mono">
                <a
                  class="pilot-card-cta-link"
                  href={`${localePath(locale, '/projects')}#${pilot.slug}`}
                >
                  {t.common.exploreThisPilot ?? (locale === 'es' ? 'Explora este piloto' : 'Explore this pilot')}<Icon name="arrow-right" />
                </a>
              </p>
            </div>
          </li>
        ))}
      </ol>

      <p class="pilots-cta">
        <a class="text-link" href={localePath(locale, '/projects')}>
          {t.cta.seeProposedPilots}<Icon name="arrow-right" />
        </a>
      </p>
    </div>
  </section>

  <!-- ====================== H6 — Participate + brand close ====================== -->
  <section id="discover-caligo" class="section section--close" aria-labelledby="h6-title">
    <span id="h6" hidden aria-hidden="true" data-legacy-anchor="h6" />
    <div class="container-wide close-layout">
      <div class="close-copy">
        <h2 id="h6-title">{h.closing.title}</h2>
        <p class="lead close-body">{h.closing.body}</p>
        <div class="close-actions">
          <a class="btn btn--primary" href={`mailto:${t.participate.contact.email}`}>
            {t.cta.contact}<Icon name="mail" />
          </a>
          <a class="text-link" href={localePath(locale, '/participate')}>
            {t.cta.howToTakePart}<Icon name="arrow-right" />
          </a>
        </div>
        <JoinCTA variant="compact" locale={locale} />
      </div>
      <aside class="close-namesake" aria-label={h.name.eyebrow}>
        <p class="namesake-eyebrow mono">{h.name.eyebrow}</p>
        <p class="namesake-sentence">
          <a class="namesake-link" href={localePath(locale, '/caligo')}>
            {h.name.body}
          </a>
        </p>
      </aside>
    </div>
  </section>

  <SourceList ids={[]} locale={locale}/>
</Base>

<style>
  /* ---- Scroll margins for semantic + legacy anchors ---- */
  #overview, #snapshot, #from-organism-to-genome,
  #questions, #proposed-pilots, #discover-caligo,
  #h1, #h2, #h3, #h4, #h5, #h6 { scroll-margin-top: 5rem; }

  /* ---- H1 Cinematic hero ---- */
  .hero-cinematic {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(30rem, 82vh, 48rem);
    background: #0d0e10;
    border-bottom: 1px solid var(--hairline);
  }
  .hero-media-frame {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-media-frame :global(.hero-media) {
    width: 100%;
    height: 100%;
    margin: 0;
  }
  .hero-media-frame :global(.hero-media picture),
  .hero-media-frame :global(.hero-media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }
  .hero-cinematic::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(0,0,0,0) 0%,
      rgba(0,0,0,0) 45%,
      rgba(10,10,12,0.42) 78%,
      rgba(6,8,10,0.62) 100%
    );
    pointer-events: none;
  }
  .hero-overlay {
    position: relative;
    z-index: 2;
    min-height: inherit;
    display: flex;
    align-items: flex-end;
    padding-block: clamp(2rem,6vh,4rem) clamp(2.5rem,8vh,5rem);
  }
  .hero-overlay-inner { width: 100%; }
  .hero-copy {
    max-width: 40rem;
    margin-left: auto;
    color: #F6F7F3;
  }
  .hero-eyebrow {
    margin: 0;
    font-size: var(--step--2);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklab, #F6F7F3 78%, transparent);
    text-shadow: 0 1px 6px rgba(0,0,0,0.45);
  }
  .hero-title {
    margin-top: var(--space-s);
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3.3vw, 3.25rem);
    font-weight: 560;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #F6F7F3;
    max-width: 24ch;
    text-wrap: balance;
    text-shadow: 0 1px 16px rgba(0,0,0,0.45);
  }
  .hero-tagline {
    margin-top: var(--space-m);
    max-width: 34ch;
    font-size: var(--step-0);
    line-height: 1.5;
    color: color-mix(in oklab, #F6F7F3 92%, transparent);
    text-shadow: 0 1px 12px rgba(0,0,0,0.5);
  }
  .hero-actions {
    margin-top: var(--space-l);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }
  .hero-btn-primary {
    background: #F6F7F3;
    color: #262524;
    border-color: transparent;
  }
  .hero-btn-primary:hover { background: #FFFFFF; color: #1a1a1a; }
  .hero-btn-ghost {
    background: transparent;
    color: #F6F7F3;
    border: 1px solid color-mix(in oklab, #F6F7F3 45%, transparent);
  }
  .hero-btn-ghost:hover {
    background: color-mix(in oklab, #F6F7F3 12%, transparent);
    border-color: #F6F7F3;
    color: #F6F7F3;
  }
  .hero-attribution {
    position: absolute;
    z-index: 3;
    bottom: 0.75rem;
    right: clamp(1rem, 3vw, 1.6rem);
    margin: 0;
    max-width: 44ch;
    text-align: right;
    font-size: 0.75rem;
    line-height: 1.4;
    color: color-mix(in oklab, #F6F7F3 64%, transparent);
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    pointer-events: auto;
  }
  .hero-attribution a {
    color: color-mix(in oklab, #F6F7F3 80%, transparent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, #F6F7F3 30%, transparent);
    text-underline-offset: 0.15em;
  }
  .hero-attribution a:hover { color: #F6F7F3; text-decoration-color: currentColor; }
  @media (max-width: 60rem) {
    /* Mobile hero — translate the desktop's horizontal composition into a
       vertical one: photograph first, then a dedicated dark copy field. */
    .hero-cinematic {
      min-height: auto;
      background: #0d0e10;
    }
    .hero-cinematic::before { display: none; }
    .hero-media-frame {
      position: absolute;
      inset: 0 0 auto 0;
      height: clamp(15rem, 33svh, 19rem);
    }
    .hero-media-frame::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        rgba(13,14,16,0) 0%,
        rgba(13,14,16,0) 58%,
        rgba(13,14,16,0.35) 76%,
        #0d0e10 100%
      );
    }
    .hero-media-frame :global(.hero-media picture),
    .hero-media-frame :global(.hero-media img) {
      object-position: 34% 42%;
    }
    .hero-overlay {
      min-height: auto;
      align-items: flex-start;
      padding-block: calc(clamp(15rem, 33svh, 19rem) - 0.35rem) 1rem;
    }
    .hero-copy {
      max-width: 100%;
      margin-left: 0;
    }
    .hero-eyebrow {
      font-size: 0.68rem;
      line-height: 1.4;
    }
    .hero-title {
      margin-top: 0.55rem;
      max-width: 20ch;
      font-size: clamp(1.75rem, 7.2vw, 2.15rem);
      line-height: 1.06;
      text-wrap: pretty;
    }
    .hero-tagline {
      margin-top: 0.9rem;
      max-width: 38ch;
      font-size: 0.94rem;
      line-height: 1.48;
    }
    .hero-actions {
      margin-top: 1.1rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
    .hero-actions .btn {
      width: 100%;
      min-height: 2.8rem;
      justify-content: space-between;
      padding: 0.7rem 1rem;
      font-size: 0.9rem;
    }
    .hero-attribution {
      position: relative;
      inset: auto;
      margin: 0;
      padding: 0 1rem 0.85rem;
      max-width: none;
      text-align: left;
      font-size: 0.58rem;
      line-height: 1.4;
      color: rgba(246,247,243,0.58);
    }
  }

  /* ---- Common section rhythm ---- */
  .section { padding-block: var(--space-xl); }
  .section > .container-wide > * + * { margin-top: var(--space-m); }
  .section h2 { max-width: 32ch; }
  .section .lead { max-width: var(--measure); }
  .section--panel {
    background: var(--bg-raised);
    border-block: 1px solid var(--hairline);
  }
  .section-eyebrow {
    margin: 0;
    font-size: var(--step--2);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* ---- H2 Why Caligo — four-principle list ---- */
  .why-list {
    list-style: none;
    padding: 0;
    margin: var(--space-l) 0 0;
    display: grid;
    gap: var(--space-l);
    grid-template-columns: 1fr;
  }
  @media (min-width: 48rem) {
    .why-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 75rem) {
    .why-list { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  .why-item {
    padding-top: var(--space-m);
    border-top: 2px solid var(--accent);
  }
  .why-item-title {
    margin: 0 0 0.4rem;
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 620;
    color: var(--text-strong);
    letter-spacing: -0.006em;
  }
  .why-item-body {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: 28ch;
  }

  /* ---- H3 Journey (vertical 1→6 with per-step media) ---- */
  .journey-intro { max-width: var(--measure); }
  .journey-vertical {
    list-style: none;
    padding: 0;
    margin: var(--space-l) 0 0;
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: 1fr;
  }
  .journey-vertical .journey-step {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-m);
    padding: 0;
    border: none;
    scroll-margin-top: 5rem;
  }
  .journey-copy {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }
  .journey-step-index {
    margin: 0;
    font-size: var(--step-1);
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .journey-step-title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--step-2);
    font-weight: 620;
    line-height: 1.3;
    color: var(--text-strong);
    letter-spacing: -0.006em;
  }
  .journey-step-body {
    margin: 0;
    max-width: 46ch;
    color: var(--text-muted);
    line-height: 1.5;
    font-size: var(--step-0);
  }
  .journey-media { min-width: 0; }
  @media (min-width: 60rem) {
    .journey-vertical .journey-step {
      grid-template-columns: minmax(0,1fr) minmax(0,1.15fr);
      gap: var(--space-xl);
      align-items: center;
    }
    .journey-vertical .journey-step:nth-child(even) .journey-copy { order: 2; }
    .journey-vertical .journey-step:nth-child(even) .journey-media { order: 1; }
  }

  /* ---- H4 Question teasers ---- */
  .question-teasers {
    list-style: none;
    padding: 0;
    margin: var(--space-l) 0 0;
    border-top: 1px solid var(--hairline-strong);
  }
  .question-teaser {
    border-bottom: 1px solid var(--hairline);
  }
  .question-teaser-link {
    display: grid;
    grid-template-columns: 3rem 1fr auto auto;
    gap: var(--space-s);
    align-items: center;
    padding-block: var(--space-m);
    text-decoration: none;
    color: var(--text);
    transition: color var(--transition);
  }
  .question-teaser-link:hover,
  .question-teaser-link:focus-visible {
    color: var(--text-strong);
  }
  .question-teaser-link:hover .question-teaser-index,
  .question-teaser-link:focus-visible .question-teaser-index {
    color: var(--accent);
  }
  .question-teaser-link :global(svg) {
    flex: none;
    width: 1rem;
    height: 1rem;
    color: var(--text-faint);
    transition: transform var(--transition), color var(--transition);
  }
  .question-teaser-link:hover :global(svg),
  .question-teaser-link:focus-visible :global(svg) {
    color: var(--accent);
    transform: translateX(3px);
  }
  .question-teaser-index {
