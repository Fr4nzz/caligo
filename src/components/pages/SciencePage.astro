---
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import SectionRail from '../SectionRail.astro';
import DataTierProgression from '../DataTierProgression.astro';
import ConceptDiagram from '../ConceptDiagram.astro';
import SourceList from '../SourceList.astro';
import { getDict, type Locale } from '../../i18n';
import { renderCitations } from '../../lib/citations';
import { getClaim } from '../../data/records';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);
const s = t.science;

const describedClaim = getClaim('lepidoptera-described');

// Rail sections — five content anchors.
const railSections = [
  { id: 'questions',     label: s.questionsHeading },
  { id: 'data-levels',   label: s.recordVsGenome.heading },
  { id: 'data-tiers',    label: s.tiers.heading },
  { id: 'reusable',      label: s.provenance.heading },
  { id: 'responsibility',label: s.ethics.heading },
];

// Stable anchors for ALL SIX science questions so Home teaser links land
// inside the right ledger row rather than at the top of #questions. The
// slug order MUST match `questionAnchors` in HomePage.astro AND the DOM
// order of `t.science.questions` — Home now renders all six as concise
// hooks (see v7.4 correction in HomePage.astro). Locale-neutral IDs so
// language switching preserves the semantic target.
const sciQuestionAnchors: readonly (string | undefined)[] = [
  'chromosomes',
  'gene-flow',
  'species-boundaries',
  'connectivity',
  'seasonal-movement',
  'biodiversity-reuse',
];

// Bilingual layer labels for the four-layer question body.
const layer = locale === 'es'
  ? {
      example:   'Un ejemplo neotropical',
      evidence:  'Qué evidencia se necesita',
      boundary:  'Un límite declarado',
      sources:   'Evidencia y fuentes',
    }
  : {
      example:   'A Neotropical example',
      evidence:  'What evidence is needed',
      boundary:  'One stated boundary',
      sources:   'Evidence and sources',
    };

const diagramIntro = locale === 'es'
  ? {
      heading: 'Dos estructuras que la genómica puede poner a prueba',
      body: 'Estos esquemas explican las relaciones que se comparan. No representan cromosomas, poblaciones, localidades ni resultados de Caligo.',
      label: 'Esquemas educativos de conceptos genómicos',
    }
  : {
      heading: 'Two structures that genomics can test',
      body: 'These schematics explain the relationships being compared. They do not represent Caligo chromosomes, populations, locations, or results.',
      label: 'Educational schematics of genomic concepts',
    };

// All source IDs referenced on this page (via [S##] tokens + described-species claim S01).
const pageSourceIds = [
  'wright-2026',
  'rueda-2024',
  'mackay-smith-2026',
  'rosser-2024',
  'edelman-2019',
  'seraphim-2016',
  'iucn-parides-2018',
  'icmbio-parides-2021',
  'gallice-2020',
  'mayer-2021',
  'st-laurent-2018',
  'fair-2016',
  'care-2020',
  'nagoya',
];
---

<Base locale={locale} title={s.metaTitle} description={s.metaDescription} page="/science">
  <PageHeader title={s.title} intro={s.intro} />

  {describedClaim && describedClaim.publish && (
    <div class="claim-block container-wide">
      <p class="claim-headline" set:html={renderCitations(describedClaim.headline[locale] + ' [S01]')} />
      {describedClaim.detail && (
        <p class="claim-detail muted">{describedClaim.detail[locale]}</p>
      )}
    </div>
  )}

  <div class="science-layout section-rail-layout section-rail-layout--wide section--tight">
    <SectionRail locale={locale} sections={railSections} />

    <div class="science-sections">
      <!-- ═══════════════════ S1 · Six questions ═══════════════════ -->
      <section id="questions" aria-labelledby="questions-heading">
        <h2 id="questions-heading">{s.questionsHeading}</h2>

        <ol class="questions-ledger" role="list">
          {
            s.questions.map((q, i) => (
              <li class="question-row" id={sciQuestionAnchors[i] ?? undefined}>
                <details class="disclosure">
                  <summary class="disclosure-summary">
                    <span class="disclosure-summary-inner">
                      <span class="question-summary-content">
                        <span class="question-index mono" aria-hidden="true">
                          Q{String(i + 1).padStart(2, '0')}
                        </span>
                        <span class="question-heading">{q.heading}</span>
                      </span>
                    </span>
                  </summary>

                  <div class="disclosure-body question-body">
                    {/* Layer 1 — concise answer */}
                    <p class="question-answer" set:html={renderCitations(q.answer)} />

                    {/* Layer 2 — A Neotropical example */}
                    <div class="question-layer">
                      <p class="layer-label">{layer.example}</p>
                      <p class="layer-text" set:html={renderCitations(q.example)} />
                    </div>

                    {/* Layer 3 — What evidence is needed */}
                    <div class="question-layer">
                      <p class="layer-label">{layer.evidence}</p>
                      <p class="layer-text" set:html={renderCitations(q.evidence)} />
                    </div>

                    {/* Layer 4 — One stated boundary */}
                    <div class="question-layer">
                      <p class="layer-label">{layer.boundary}</p>
                      <p class="layer-text" set:html={renderCitations(q.limits)} />
                    </div>

                    {/* Compact Evidence and sources sub-disclosure */}
                    <details class="disclosure disclosure--compact question-sources-disclosure">
                      <summary class="disclosure-summary">
                        <span class="disclosure-summary-inner">{layer.sources}</span>
                      </summary>
                      <div class="disclosure-body">
                        <p class="source-note" set:html={renderCitations(q.sourceNote)} />
                      </div>
                    </details>
                  </div>
                </details>
              </li>
            ))
          }
        </ol>

        <aside class="science-concepts" aria-labelledby="science-concepts-heading">
          <div class="science-concepts-intro">
            <h3 id="science-concepts-heading">{diagramIntro.heading}</h3>
            <p>{diagramIntro.body}</p>
          </div>
          <div class="science-concept-grid" aria-label={diagramIntro.label}>
            <ConceptDiagram locale={locale} kind="chromosome" context="science" />
            <ConceptDiagram locale={locale} kind="connectivity" context="science" />
          </div>
        </aside>
      </section>

      <!-- ═══════════════════ S2 · Data levels (record vs genome) ═══════════════════ -->
      <section id="data-levels" aria-labelledby="dl-heading">
        <h2 id="dl-heading">{s.recordVsGenome.heading}</h2>
        <p class="section-intro muted">{s.recordVsGenome.intro}</p>

        <dl class="rvg-ledger">
          <div class="rvg-row rvg-row--head" aria-hidden="true">
            <span class="rvg-col-label">{s.recordVsGenome.labels.recordColHeading}</span>
            <span class="rvg-col-label">{s.recordVsGenome.labels.canShow}</span>
            <span class="rvg-col-label">{s.recordVsGenome.labels.cannotEstablish}</span>
          </div>
          {
            s.recordVsGenome.rows.map((r) => (
              <div class="rvg-row">
                <dt class="rvg-record">{r.record}</dt>
                <dd class="rvg-cell">
                  <span class="rvg-inline-label">{s.recordVsGenome.labels.canShow}</span>
                  <span class="rvg-value">{r.canShow}</span>
                </dd>
                <dd class="rvg-cell">
                  <span class="rvg-inline-label">{s.recordVsGenome.labels.cannotEstablish}</span>
                  <span class="rvg-value">{r.cannotEstablish}</span>
                </dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- ═══════════════════ S2b · Data tiers ═══════════════════ -->
      <section id="data-tiers" aria-labelledby="tiers-heading">
        <h2 id="tiers-heading">{s.tiers.heading}</h2>
        <p class="section-intro muted">{s.tiers.intro}</p>
        <DataTierProgression locale={locale} />
      </section>

      <!-- ═══════════════════ S3 · Reusable — evidence-chain list ═══════════════════ -->
      <section id="reusable" aria-labelledby="prov-heading">
        <h2 id="prov-heading">{s.provenance.heading}</h2>
        <p class="section-intro muted">{s.provenance.intro}</p>

        <ol class="provenance-list">
          {
            s.provenance.fields.map((f, i) => (
              <li>
                <span class="prov-index mono" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="prov-field">{f}</span>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- ═══════════════════ S4 · Responsibility ═══════════════════ -->
      <section id="responsibility" aria-labelledby="resp-heading">
        <h2 id="resp-heading">{s.ethics.heading}</h2>
        <p class="section-intro muted">{s.ethics.intro}</p>

        <ol class="ethics-list">
          {
            s.ethics.questions.map((q, i) => (
              <li>
                <span class="ethics-index mono" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="ethics-text">{q}</span>
              </li>
            ))
          }
        </ol>

        <p class="external-context muted" set:html={renderCitations(s.ethics.externalContext)} />
        <p class="disclaimer" role="note">{s.ethics.disclaimer}</p>
      </section>
    </div>
  </div>

  <div class="container-wide">
    <SourceList ids={pageSourceIds} locale={locale} />
  </div>
</Base>

<style>
  /* ═══════════════════ Described-species claim block ═══════════════════ */
  .claim-block {
    margin-block: var(--space-l);
    padding: var(--space-m) var(--space-l);
    background: var(--bg-inset);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .claim-headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    color: var(--text-strong);
    line-height: 1.3;
  }
  .claim-detail {
    margin: var(--space-2xs) 0 0;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.5;
    max-width: var(--measure);
  }

  /* ═══════════════════ Layout — rail + content ═══════════════════ */
  .science-layout {
    /* Width, columns and breakpoint are owned by the shared
       .section-rail-layout primitive in global.css. */
  }
  .science-sections {
    min-width: 0;
  }
  .science-sections > section {
    scroll-margin-top: var(--scroll-margin-top);
  }
  .science-sections > section + section {
    margin-top: var(--space-xl);
  }
  .science-sections h2 {
    margin-top: 0.5rem;
    margin-bottom: var(--space-s);
    max-width: 26ch;
  }
  .section-intro {
    max-width: var(--measure);
    margin-bottom: var(--space-m);
  }

  /* Shared micro-label */
  .rvg-col-label,
  .rvg-inline-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .rvg-col-label {
    color: var(--accent-strong);
    letter-spacing: 0.14em;
  }

  /* ═══════════════════ S1 · Questions ledger ═══════════════════ */
  .questions-ledger {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }
  .question-row {
    border-bottom: 1px solid var(--hairline);
  }

  .science-concepts {
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid var(--hairline-strong);
  }
  .science-concepts-intro {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(16rem, 1.2fr);
    gap: var(--space-m);
    align-items: baseline;
    margin-bottom: var(--space-m);
  }
  .science-concepts-intro h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--text-strong);
  }
  .science-concepts-intro p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }
  .science-concept-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-m);
  }
  @media (max-width: 58rem) {
    .science-concepts-intro,
    .science-concept-grid { grid-template-columns: 1fr; }
  }
  .questions-ledger .disclosure { --disclosure-pad-x: 0; }
  .questions-ledger .disclosure-summary { padding-block: var(--space-s); }

  /* Q01 + heading cluster */
  .question-summary-content {
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    min-width: 0;
    flex: 1 1 auto;
  }
  .question-index {
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    flex: 0 0 3rem;
  }
  .question-heading {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    line-height: 1.25;
    letter-spacing: -0.006em;
    color: var(--text-strong);
    max-width: 52ch;
  }

  /* Question body — indent to align with heading text */
  .question-body {
    padding-inline-start: 3rem;
    display: grid;
    gap: var(--space-s);
  }
  .question-answer {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
    max-width: var(--measure);
  }

  /* Four-layer structure */
  .question-layer {
    border-left: 2px solid var(--hairline-strong);
    padding-left: var(--space-m);
    display: grid;
    gap: 0.25rem;
  }
  .layer-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .layer-text {
    margin: 0;
    color: var(--text);
    line-height: 1.55;
    max-width: var(--measure);
  }

  /* Sources sub-disclosure inside the question body */
  .question-sources-disclosure {
    margin-top: var(--space-2xs);
  }
  .source-note {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.5;
    max-width: var(--measure);
  }

  /* ═══════════════════ S2 · Data levels ledger ═══════════════════ */
  .rvg-ledger {
    display: grid;
    gap: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }
  .rvg-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-s);
    padding: var(--space-m) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .rvg-row--head {
    display: none;
  }
  .rvg-record {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    line-height: 1.2;
    color: var(--text-strong);
    margin: 0;
  }
  .rvg-cell {
    display: grid;
    gap: 0.35rem;
    margin: 0;
    max-width: var(--measure);
  }
  .rvg-value {
    color: var(--text);
    line-height: 1.55;
  }
  @media (min-width: 60rem) {
    .rvg-row {
      grid-template-columns: 1.15fr 1fr 1fr;
      column-gap: var(--space-m);
      align-items: baseline;
    }
    .rvg-row--head {
      display: grid;
      padding-block: var(--space-s);
      border-bottom: 1px solid var(--hairline-strong);
    }
    .rvg-inline-label {
      display: none;
    }
  }

  /* ═══════════════════ S3 · Reusable evidence-chain list ═══════════════════
     Column-first flow at ≥46rem; break-inside: avoid keeps each item intact. */
  .provenance-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
    display: block;
  }
  .provenance-list li {
    display: grid;
    grid-template-columns: 2.75rem 1fr;
    gap: var(--space-s);
    align-items: baseline;
    padding: var(--space-s) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .prov-index {
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .prov-field {
    color: var(--text);
    line-height: 1.5;
  }
  @media (min-width: 46rem) {
    .provenance-list {
      column-count: 2;
      column-gap: var(--space-xl);
    }
    .provenance-list li {
      break-inside: avoid;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
    }
  }

  /* ═══════════════════ S4 · Responsibility ═══════════════════ */
  .ethics-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }
  .ethics-list li {
    display: grid;
    grid-template-columns: 2.75rem 1fr;
    gap: var(--space-s);
    align-items: baseline;
    padding: var(--space-s) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .ethics-index {
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.06em;
  }
  .ethics-text {
    color: var(--text);
    line-height: 1.55;
    max-width: var(--measure);
  }
  .external-context {
    margin-top: var(--space-l);
    max-width: var(--measure);
    font-size: var(--step--1);
  }
  .disclaimer {
    margin-top: var(--space-m);
    padding: var(--space-s) var(--space-m);
    border-left: 3px solid var(--highlight);
    background: var(--bg-inset);
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: var(--measure);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
</style>
