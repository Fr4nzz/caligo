---
/**
 * AboutPage — editorial prose with wide visual systems where cards need room.
 *
 * Four sections:
 *   A1  PageHeader — title + intro (about.title / about.body).
 *   A2  Scope — what Caligo is and is not (about.body as full prose
 *       paragraph; single narrow-measure column).
 *   A3  Principles — the eight guiding principles via PrincipleGrid
 *       as the "how the work is shaped" section; responsive card rows).
 *   A4  Aims — what Caligo brings together (about.beingDecided.questions
 *       as a numbered list; single column).
 *
 * Prose uses the narrow reading container. Principles and leadership use the
 * wide container so their shared cards keep a readable minimum width.
 * about.externalContext is rendered as a restrained note below aims.
 * about.beingDecided is reused here under the "aims" framing — the i18n
 * key name is legacy but the copy remains editorially correct.
 */
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import ObjectiveList from '../ObjectiveList.astro';
import PrincipleGrid from '../PrincipleGrid.astro';
import LeadershipGrid from '../LeadershipGrid.astro';
import SourceList from '../SourceList.astro';
import { getDict, type Locale } from '../../i18n';
import { GOVERNANCE_POINTS } from '../../data/initiative';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);
const a = t.about;
const h = t.home;
---

<Base locale={locale} title={a.metaTitle} description={a.metaDescription} page="/about">

  <!-- A1 — Header -->
  <PageHeader eyebrow={t.nav.about} title={a.title} intro={a.body} />

  <!-- A2 — Scope: what Caligo is -->
  <section class="section section--tight" aria-labelledby="about-scope">
    <div class="container-narrow">
      <h2 id="about-scope" class="section-heading">{h.intro.title}</h2>
      <div class="prose-block">
        {h.intro.body.map((para) => (
          <p class="prose-para">{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- A2b — The name as a present-day statement of the initiative's purpose -->
  <section class="section section--tight section--panel" aria-labelledby="about-name">
    <div class="container-narrow name-story">
      <h2 id="about-name" class="section-heading">{a.name.heading}</h2>
      <div class="prose-block">
        {a.name.body.map((para) => (
          <p class="prose-para">{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- A3 — Principles: the initiative's eight guiding principles -->
  <section class="section section--tight" aria-labelledby="about-principles">
    <div class="container-wide visual-section">
      <p class="section-eyebrow mono">{h.pillars.eyebrow}</p>
      <h2 id="about-principles" class="section-heading">{h.pillars.title}</h2>
      <PrincipleGrid locale={locale}/>
    </div>
  </section>

  <!-- A4 — Objectives: strategic goals -->
  <section class="section section--tight" aria-labelledby="about-objectives">
    <div class="container-narrow">
      <h2 id="about-objectives" class="section-heading">{a.objectives.heading}</h2>
      <p class="prose-para">{a.objectives.intro}</p>
      <ObjectiveList locale={locale}/>

      <!-- External context: restrained note + disclaimer (defect 8) -->
      <aside class="external-note" aria-label={a.externalContext.heading}>
        <h3 class="external-note-heading">{a.externalContext.heading}</h3>
        <p class="external-note-body">{a.externalContext.body}</p>
        <p class="disclaimer" role="note">{a.externalContext.disclaimer}</p>
      </aside>
    </div>
  </section>

  <!-- A5 — Leadership -->
  <section class="section section--tight section--panel" aria-labelledby="about-leadership">
    <div class="container-wide visual-section">
      <h2 id="about-leadership" class="section-heading">{a.leadership.heading}</h2>
      <p class="prose-para">{a.leadership.intro}</p>
      <LeadershipGrid locale={locale} />
    </div>
  </section>

  <!-- A6 — Governance -->
  <section class="section section--tight" aria-labelledby="about-governance">
    <div class="container-narrow">
      <h2 id="about-governance" class="section-heading">{a.governance.heading}</h2>
      <p class="prose-para">{a.governance.intro}</p>
      <ul class="governance-list" role="list">
        {GOVERNANCE_POINTS.map((pt) => (
          <li class="governance-item">{pt[locale]}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- A7 — Vision and Mission -->
  <section class="section section--tight section--panel" aria-labelledby="about-vision">
    <div class="container-narrow">
      <h2 id="about-vision" class="section-heading">{a.vision.heading}</h2>
      <p class="prose-para">{a.vision.body}</p>
      <h2 id="about-mission" class="section-heading">{a.mission.heading}</h2>
      <p class="prose-para">{a.mission.body}</p>
    </div>
  </section>

  <SourceList ids={[]} locale={locale}/>

</Base>

<style>
  .visual-section > .section-eyebrow,
  .visual-section > .section-heading,
  .visual-section > .prose-para {
    max-width: var(--measure);
  }

  /* ---- Section rhythm ---- */
  .section { padding-block: var(--space-xl); }
  .section--tight { padding-block: var(--space-l); }
  .section--panel {
    background: var(--bg-raised);
    border-block: 1px solid var(--hairline);
  }
  .section-eyebrow {
    margin: 0 0 var(--space-s);
    font-size: var(--step--2);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .section-heading {
    margin: 0 0 var(--space-m);
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 560;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--text-strong);
  }

  /* ---- A2 Scope prose ---- */
  .prose-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }
  .prose-para {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
  }
  .name-story .prose-para:last-child {
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    line-height: 1.35;
  }

  /* ---- External note — restrained aside + disclaimer ---- */
  .external-note {
    padding: var(--space-m);
    background: var(--bg-inset);
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius);
  }
  .external-note-heading {
    margin: 0 0 var(--space-s);
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 620;
    color: var(--text-strong);
    letter-spacing: -0.006em;
  }
  .external-note-body {
    margin: 0;
    color: var(--text);
    line-height: 1.55;
    font-size: var(--step--1);
  }
  /* ---- A6 Governance list ---- */
  .governance-list {
    list-style: none;
    padding: 0;
    margin: var(--space-m) 0 0;
    border-top: 1px solid var(--hairline-strong);
  }
  .governance-item {
    padding-block: var(--space-s);
    border-bottom: 1px solid var(--hairline);
    color: var(--text);
    line-height: 1.55;
    font-size: var(--step--1);
  }

  /* Disclaimer render pattern from SciencePage.astro line 183 — defect 8. */
  .disclaimer {
    margin-top: var(--space-m);
    padding: var(--space-s) var(--space-m);
    border-left: 3px solid var(--highlight);
    background: var(--bg-inset);
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: var(--measure);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
</style>
