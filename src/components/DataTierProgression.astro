---
import { TIERS, pick } from '../data/initiative';
import type { Locale } from '../i18n';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;

const LEVELS = ['barcode', 'short-reads', 'assembly'] as const;
type Level = typeof LEVELS[number];

const progression = locale === 'es'
  ? {
      eyebrow: 'Progresión de evidencia complementaria',
      heading: 'De un fragmento dirigido al contexto cromosómico',
      note: 'Cada nivel amplía las preguntas posibles; no reemplaza al anterior.',
      platforms: 'Plataformas',
      labels: ['Región dirigida', 'Muestreo de todo el genoma', 'Referencia a escala cromosómica'],
    }
  : {
      eyebrow: 'Complementary evidence progression',
      heading: 'From a targeted fragment to chromosome-scale context',
      note: 'Each tier expands the questions available; it does not replace the tier before it.',
      platforms: 'Platforms',
      labels: ['Targeted region', 'Genome-wide sampling', 'Chromosome-scale reference'],
    };
---

<div class="tier-progression">
  <header class="progression-header">
    <div>
      <p class="progression-eyebrow">{progression.eyebrow}</p>
      <p class="progression-heading">{progression.heading}</p>
    </div>
    <p class="progression-note">{progression.note}</p>
  </header>

  <ol class="tier-list" role="list">
    {TIERS.map((tier, i) => {
      const level = LEVELS[i] as Level;
      return (
        <li class="tier-item" data-level={level}>
          <div class="tier-step" aria-hidden="true">
            <span class="tier-node">{tier.n}</span>
          </div>

          <div class="evidence-glyph" aria-hidden="true">
            {level === 'barcode' && (
              <svg viewBox="0 0 180 52">
                <path d="M12 26 H168" class="genome-line" />
                <rect x="76" y="17" width="28" height="18" rx="9" class="focus-region" />
                <path d="M76 11 V41 M104 11 V41" class="guide-mark" />
              </svg>
            )}
            {level === 'short-reads' && (
              <svg viewBox="0 0 180 52">
                <path d="M12 26 H168" class="genome-line" />
                <path d="M18 17 h23 M50 31 h28 M86 16 h18 M113 31 h20 M142 18 h25" class="read-fragments" />
              </svg>
            )}
            {level === 'assembly' && (
              <svg viewBox="0 0 180 52">
                <rect x="12" y="17" width="156" height="18" rx="9" class="assembly-bar" />
                <path d="M48 18 V34 M86 18 V34 M127 18 V34" class="assembly-joins" />
              </svg>
            )}
          </div>

          <p class="tier-level-label">{progression.labels[i]}</p>
          <h3 class="tier-title">{pick(tier.title, locale)}</h3>
          <p class="tier-body">{pick(tier.body, locale)}</p>
          <p class="tier-platforms">
            <span class="tier-platforms-label">{progression.platforms}:</span>
            {' '}{pick(tier.platforms, locale)}
          </p>
        </li>
      );
    })}
  </ol>
</div>

<style>
  .tier-progression {
    overflow: hidden;
    background: var(--bg-panel);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
  }
  .progression-header {
    display: grid;
    gap: var(--space-s);
    padding: var(--space-m);
    background: var(--bg-inset);
    border-bottom: 1px solid var(--hairline);
  }
  .progression-eyebrow,
  .progression-heading,
  .progression-note {
    margin: 0;
  }
  .progression-eyebrow,
  .tier-level-label,
  .tier-platforms-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 550;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .progression-eyebrow {
    color: var(--accent-strong);
    margin-bottom: 0.25rem;
  }
  .progression-heading {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 600;
    color: var(--text-strong);
    line-height: 1.25;
  }
  .progression-note {
    align-self: end;
    max-width: 34rem;
    color: var(--text-muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }
  .tier-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
  }
  .tier-item {
    position: relative;
    min-width: 0;
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr);
    column-gap: var(--space-s);
    padding: var(--space-m);
  }
  .tier-item + .tier-item {
    border-top: 1px solid var(--hairline);
  }
  .tier-step {
    grid-column: 1;
    grid-row: 1 / span 5;
    position: relative;
    display: flex;
    justify-content: center;
  }
  .tier-step::after {
    content: '';
    position: absolute;
    top: 2.6rem;
    bottom: calc(-1 * var(--space-m) - 1px);
    left: 50%;
    width: 1px;
    background: var(--hairline-strong);
  }
  .tier-item:last-child .tier-step::after { display: none; }
  .tier-node {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 2.55rem;
    height: 2.55rem;
    border: 1px solid var(--accent);
    border-radius: 50%;
    background: var(--bg-panel);
    color: var(--accent-strong);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 650;
    letter-spacing: 0.03em;
  }
  .evidence-glyph {
    grid-column: 2;
    width: min(100%, 15rem);
    height: 3.25rem;
    margin-bottom: var(--space-xs);
    color: var(--accent);
  }
  .evidence-glyph svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .genome-line,
  .guide-mark,
  .read-fragments,
  .assembly-joins {
    fill: none;
    stroke-linecap: round;
  }
  .genome-line { stroke: var(--hairline-strong); stroke-width: 4; }
  .guide-mark { stroke: var(--text-faint); stroke-width: 1.5; }
  .focus-region { fill: var(--highlight); }
  .read-fragments { stroke: var(--accent-strong); stroke-width: 6; }
  .assembly-bar { fill: var(--accent); }
  .assembly-joins { stroke: var(--bg-panel); stroke-width: 2; opacity: 0.75; }
  .tier-level-label {
    grid-column: 2;
    margin: 0 0 0.35rem;
    color: var(--text-faint);
  }
  .tier-title {
    grid-column: 2;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 650;
    color: var(--text-strong);
    letter-spacing: -0.006em;
    line-height: 1.3;
  }
  .tier-body {
    grid-column: 2;
    margin: var(--space-xs) 0 0;
    font-size: var(--step--1);
    color: var(--text);
    line-height: 1.58;
  }
  .tier-platforms {
    grid-column: 2;
    margin: var(--space-s) 0 0;
    padding-top: var(--space-xs);
    border-top: 1px solid var(--hairline);
    font-size: var(--step--2);
    color: var(--text-muted);
    line-height: 1.5;
  }
  .tier-platforms-label {
    color: var(--text-faint);
    letter-spacing: 0.07em;
  }
  @media (min-width: 48rem) {
    .progression-header {
      grid-template-columns: minmax(0, 1.25fr) minmax(15rem, 0.75fr);
      align-items: end;
    }
    .tier-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .tier-item {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto 1fr auto;
      padding: var(--space-m);
    }
    .tier-item + .tier-item {
      border-top: 0;
      border-left: 1px solid var(--hairline);
    }
    .tier-step {
      grid-column: 1;
      grid-row: 1;
      justify-content: flex-start;
      margin-bottom: var(--space-s);
    }
    .tier-step::after {
      top: 50%;
      bottom: auto;
      left: 2.55rem;
      right: calc(-1 * var(--space-m) - 1px);
      width: auto;
      height: 1px;
    }
    .tier-item:last-child .tier-step::after { display: none; }
    .evidence-glyph,
    .tier-level-label,
    .tier-title,
    .tier-body,
    .tier-platforms { grid-column: 1; }
    .evidence-glyph { grid-row: 2; width: 100%; }
    .tier-level-label { grid-row: 3; }
    .tier-title { grid-row: 4; }
    .tier-body { grid-row: 5; }
    .tier-platforms { grid-row: 6; }
  }
</style>
