  .vch-idtag--sm { font-size: 6.5px; }
  .vch-cap { fill: var(--accent-strong); }
  .vch-tube { fill: color-mix(in oklab, var(--accent) 7%, var(--bg-panel)); stroke: var(--hairline-strong); stroke-width: 1.5; }
  .vch-label { fill: var(--text-strong); opacity: 0.88; }
  .vch-barcode { fill: none; stroke: var(--bg-panel); stroke-width: 1.4; }
  .vch-barcode--row { fill: none; stroke: var(--accent-strong); stroke-width: 1.3; }
  .vch-body-inside { fill: color-mix(in oklab, var(--accent) 42%, transparent); stroke: var(--accent); stroke-width: 1; }
  .vch-sheet { fill: var(--bg-panel); stroke: var(--hairline-strong); stroke-width: 1.5; }
  .vch-sheet-head { fill: color-mix(in oklab, var(--accent) 14%, transparent); }
  .vch-row-hit { fill: color-mix(in oklab, var(--accent) 20%, transparent); }
  .vch-row-wing { fill: color-mix(in oklab, var(--accent) 34%, var(--bg-panel)); }
  .vch-grid { fill: none; stroke: var(--hairline-strong); stroke-width: 1; opacity: 0.5; }
  .vch-cell { fill: none; stroke: var(--text-faint); stroke-width: 3; stroke-linecap: round; }
  .vch-flow { fill: none; stroke: var(--text-muted); stroke-width: 2; stroke-linecap: round; }
  .vch-flow--split { stroke: var(--hairline-strong); stroke-width: 1.5; stroke-dasharray: 3 4; opacity: 0.75; }

  .vch-wings-l,
  .vch-wings-r,
  .vch-ghost-wings,
  .vch-ghost-body,
  .vch-cap-group,
  .vch-env-wings,
  .vch-body-inside,
  .vch-row-hit,
