---
import type { Locale } from '../i18n';

type DiagramKind = 'chromosome' | 'connectivity' | 'monitoring' | 'migration' | 'voucher';

interface Props {
  readonly locale: Locale;
  readonly kind: DiagramKind;
  readonly context?: 'science' | 'pilot';
}

const { locale, kind, context = 'science' } = Astro.props;
const id = `concept-${context}-${kind}`;

const copy = {
  en: {
    conceptual: 'Educational animation — conceptual, not data',
    play: 'Play the explanation',
    replay: 'Replay',
    ready: 'Ready to animate',
    playing: 'Explanation playing',
    finished: 'Explanation complete',
    chromosome: {
      title: 'Chromosome fission and fusion',
      desc: 'A simplified Lepidoptera schematic. In fission, one chromosome breaks at an internal position and the two fragments become separate chromosomes after their new ends are stabilised. In fusion, an orange chromosome and a yellow chromosome join end-to-end, retaining both coloured regions in one chromosome. The colours track chromosome regions; chromosomes are not literally orange or yellow. Lepidoptera have holocentric chromosomes, with no single localised centromere. The exact break point and junction vary; this is not a Caligo result.',
      one: 'one chromosome',
      two: 'two chromosomes',
      joined: 'one joined chromosome',
      fission: 'fission',
      fusion: 'fusion',
      breakpoint: 'internal break point',
      newEnds: 'two fragments · new ends stabilised',
      junction: 'orange + yellow · end-to-end junction',
      holocentric: 'Holocentric in Lepidoptera · colours track chromosome regions',
      question: 'compare chromosome-scale assemblies',
    },
    connectivity: {
      title: 'Population connectivity and gene flow',
      desc: 'A simplified one-locus example. Each large circle is an individual; its two inner symbols are two inherited allele copies. Population B begins without the solid orange allele. An orange-carrying individual moves from population A and reproduces with a resident. Their offspring inherits one allele from each parent, introducing the orange allele into population B. Movement without successful reproduction would be migration, but not gene flow in this example. Colours and positions are conceptual, not measured populations, allele frequencies, routes, or results.',
      populationA: 'population A',
      populationB: 'population B',
      orangeAllele: 'solid orange allele',
      blueAllele: 'blue ring allele',
      absent: 'orange allele absent at start',
      moves: 'migrant carries orange allele',
      parents: 'migrant + resident',
      offspring: 'offspring',
      inheritance: 'one allele from each parent',
      enters: 'orange allele enters population B',
      legend: 'one circle = one individual · two inner symbols = two allele copies at one simplified locus',
    },
    monitoring: {
      title: 'Movement and resistance monitoring',
      desc: 'A conceptual workflow linking repeated field sampling, confirmed species identification, tests of movement and candidate resistance-associated variants, and validated monitoring. It contains no observations or results.',
      sample: 'repeat sampling',
      identify: 'confirm species',
      movement: 'test movement',
      candidates: 'candidate variants',
      validate: 'validate monitoring',
    },
    migration: {
      title: 'Testing seasonal origins and routes',
      desc: 'A conceptual schematic in which samples across places and seasons are compared to test possible origins and connections, then interpreted with independent movement and environmental evidence. It is not a geographic map or a reconstructed route.',
      sampling: 'places + seasons',
      origins: 'possible origins?',
      routes: 'connections?',
      evidence: 'independent evidence',
    },
    voucher: {
      title: 'Voucher: specimen, sample, record',
      desc: 'A generic schematic. The wings are cut and stored in a labelled envelope (its CAMID); the body goes into a tube (its tube ID); one record row holds both identifiers. It shows no real specimen, identifier or database.',
      specimen: 'specimen',
      envelope: 'wings → envelope',
      tube: 'body → tube',
      record: 'record row',
      camid: 'CAMID',
      tubeid: 'TUBE ID',
      link: 'one CAMID links all three',
    },
  },
  es: {
    conceptual: 'Animación educativa — conceptual, no son datos',
    play: 'Reproducir la explicación',
    replay: 'Repetir',
    ready: 'Listo para animar',
    playing: 'Explicación en curso',
    finished: 'Explicación completa',
    chromosome: {
      title: 'Fisión y fusión cromosómica',
      desc: 'Esquema simplificado para Lepidoptera. En la fisión, un cromosoma se rompe en una posición interna y los dos fragmentos se convierten en cromosomas separados después de estabilizar sus nuevos extremos. En la fusión, un cromosoma naranja y uno amarillo se unen extremo con extremo y conservan ambas regiones de color en un solo cromosoma. Los colores siguen regiones cromosómicas; los cromosomas no son literalmente naranjas o amarillos. Los Lepidoptera tienen cromosomas holocéntricos, sin un único centrómero localizado. El punto de ruptura y la unión pueden variar; no es un resultado de Caligo.',
      one: 'un cromosoma',
      two: 'dos cromosomas',
      joined: 'un cromosoma unido',
      fission: 'fisión',
      fusion: 'fusión',
      breakpoint: 'punto de ruptura interno',
      newEnds: 'dos fragmentos · nuevos extremos estabilizados',
      junction: 'naranja + amarillo · unión extremo con extremo',
      holocentric: 'Holocéntricos en Lepidoptera · los colores siguen regiones cromosómicas',
      question: 'comparar ensamblajes a escala cromosómica',
    },
    connectivity: {
      title: 'Conectividad poblacional y flujo génico',
      desc: 'Ejemplo simplificado de un locus. Cada círculo grande es un individuo; sus dos símbolos internos son dos copias heredadas de un alelo. La población B comienza sin el alelo naranja sólido. Un individuo que porta el alelo naranja se desplaza desde la población A y se reproduce con un residente. Su descendiente hereda un alelo de cada progenitor e introduce el alelo naranja en la población B. El movimiento sin reproducción exitosa sería migración, pero no flujo génico en este ejemplo. Los colores y posiciones son conceptuales; no son poblaciones, frecuencias alélicas, rutas ni resultados medidos.',
      populationA: 'población A',
      populationB: 'población B',
      orangeAllele: 'alelo naranja sólido',
      blueAllele: 'alelo azul con contorno',
      absent: 'alelo naranja ausente al inicio',
      moves: 'migrante porta el alelo naranja',
      parents: 'migrante + residente',
      offspring: 'descendiente',
      inheritance: 'un alelo de cada progenitor',
      enters: 'el alelo naranja entra en la población B',
      legend: 'un círculo = un individuo · dos símbolos internos = dos copias alélicas en un locus simplificado',
    },
    monitoring: {
      title: 'Monitoreo de movimiento y resistencia',
      desc: 'Flujo conceptual que vincula muestreo de campo repetido, identificación confirmada de especies, pruebas de movimiento y variantes candidatas asociadas con resistencia, y monitoreo validado. No contiene observaciones ni resultados.',
      sample: 'repetir muestreo',
      identify: 'confirmar especie',
      movement: 'estudiar movimiento',
      candidates: 'variantes candidatas',
      validate: 'validar monitoreo',
    },
    migration: {
      title: 'Estudiar orígenes y rutas estacionales',
      desc: 'Esquema conceptual donde se comparan muestras de distintos lugares y temporadas para estudiar posibles orígenes y conexiones, y luego se interpretan con evidencia ambiental y de movimiento independiente. No es un mapa geográfico ni una ruta reconstruida.',
      sampling: 'lugares + temporadas',
      origins: '¿orígenes posibles?',
      routes: '¿conexiones?',
      evidence: 'evidencia independiente',
    },
    voucher: {
      title: 'Voucher: ejemplar, muestra, registro',
      desc: 'Esquema genérico. Las alas se cortan y se guardan en un sobre etiquetado (su CAMID); el cuerpo va a un tubo (su ID de tubo); una fila de registro reúne ambos identificadores. No muestra un ejemplar, un identificador ni una base de datos reales.',
      specimen: 'ejemplar',
      envelope: 'alas → sobre',
      tube: 'cuerpo → tubo',
      record: 'fila de registro',
      camid: 'CAMID',
      tubeid: 'ID DE TUBO',
      link: 'un CAMID une los tres',
    },
  },
} as const;

const c = copy[locale];
const k = c[kind];
const mobileSteps: readonly string[] = kind === 'chromosome'
  ? [
      `${c.chromosome.one} → ${c.chromosome.breakpoint}`,
      c.chromosome.newEnds,
      `${c.chromosome.two} → ${c.chromosome.junction}`,
      c.chromosome.joined,
      c.chromosome.holocentric,
    ]
  : kind === 'connectivity'
    ? [
        `${c.connectivity.populationA}: ${c.connectivity.orangeAllele}`,
        `${c.connectivity.populationB}: ${c.connectivity.absent}`,
        c.connectivity.moves,
        `${c.connectivity.parents} → ${c.connectivity.offspring}: ${c.connectivity.inheritance}`,
        c.connectivity.enters,
        c.connectivity.legend,
      ]
    : kind === 'monitoring'
      ? [c.monitoring.sample, c.monitoring.identify, c.monitoring.movement, c.monitoring.candidates, c.monitoring.validate]
      : kind === 'migration'
        ? [c.migration.sampling, c.migration.origins, c.migration.routes, c.migration.evidence]
        : [
            c.voucher.specimen,
            `${c.voucher.envelope} (${c.voucher.camid})`,
            `${c.voucher.tube} (${c.voucher.tubeid})`,
            `${c.voucher.record}: ${c.voucher.camid} + ${c.voucher.tubeid}`,
          ];
---

<figure
  class="concept-diagram"
  data-kind={kind}
  data-context={context}
  data-concept-diagram
  data-label-play={c.play}
  data-label-replay={c.replay}
  data-label-playing={c.playing}
  data-label-finished={c.finished}
>
  <figcaption class="concept-heading">
    <span class="concept-title-group">
      <span class="concept-kicker">{c.conceptual}</span>
      <strong>{k.title}</strong>
    </span>
    <button type="button" class="concept-play" data-concept-play aria-describedby={`${id}-status`}>
      <span class="play-icon" aria-hidden="true">▶</span>
      <span data-concept-play-label>{c.play}</span>
    </button>
  </figcaption>

  <svg class="concept-svg" viewBox={kind === 'chromosome' || kind === 'connectivity' ? '0 0 600 220' : '0 0 600 190'} role="img" aria-labelledby={`${id}-title ${id}-desc`}>
    <title id={`${id}-title`}>{k.title}</title>
    <desc id={`${id}-desc`}>{k.desc}</desc>
    <defs>
      <marker id={`${id}-arrow`} viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 0 L 8 4 L 0 8 z" class="arrowhead" />
      </marker>
    </defs>

    {kind === 'chromosome' && (
      <g class="diagram-scene chromosome-scene">
        {/* Fission: one two-colour chromosome breaks at an internal point. */}
        <text x="68" y="20" class="group-label">{c.chromosome.fission}</text>
        <g class="fission-source">
          <path d="M39 37 H105 V59 H39 A11 11 0 0 1 28 48 A11 11 0 0 1 39 37 Z" class="chromosome-segment chromosome-segment--orange" />
          <path d="M105 37 H171 A11 11 0 0 1 182 48 A11 11 0 0 1 171 59 H105 Z" class="chromosome-segment chromosome-segment--yellow" />
          <rect x="28" y="37" width="154" height="22" rx="11" class="chromosome-outline" />
          <path d="M105 34 V62" class="breakpoint-line" />
        </g>
        <text x="105" y="78" class="node-label">{c.chromosome.one}</text>
        <text x="105" y="94" class="micro-label">{c.chromosome.breakpoint}</text>

        <path d="M200 48 H254" class="flow process-line process-line--one" marker-end={`url(#${id}-arrow)`} />
        <circle cx="228" cy="48" r="13" class="event-ring event-ring--one" />
        <path d="M223 40 L228 45 L233 40 M223 56 L228 51 L233 56" class="split-mark" />

        <g class="fission-product fission-product--orange">
          <rect x="282" y="37" width="76" height="22" rx="11" class="chromosome-segment chromosome-segment--orange" />
          <path d="M356 41 V55" class="new-end new-end--orange" />
        </g>
        <g class="fission-product fission-product--yellow">
          <rect x="388" y="37" width="76" height="22" rx="11" class="chromosome-segment chromosome-segment--yellow" />
          <path d="M390 41 V55" class="new-end new-end--yellow" />
        </g>
        <text x="373" y="78" class="node-label">{c.chromosome.two}</text>
        <text x="373" y="94" class="micro-label">{c.chromosome.newEnds}</text>

        {/* Fusion: distinct orange and yellow chromosomes join end-to-end. */}
        <text x="68" y="120" class="group-label">{c.chromosome.fusion}</text>
        <rect x="28" y="136" width="66" height="22" rx="11" class="chromosome-segment chromosome-segment--orange fusion-source fusion-source--orange" />
        <rect x="118" y="136" width="66" height="22" rx="11" class="chromosome-segment chromosome-segment--yellow fusion-source fusion-source--yellow" />
        <text x="106" y="178" class="node-label">{c.chromosome.two}</text>

        <path d="M200 147 H254" class="flow process-line process-line--two" marker-end={`url(#${id}-arrow)`} />
        <circle cx="228" cy="147" r="13" class="event-ring event-ring--two" />
        <path d="M222 141 L228 147 L234 141 M222 153 L228 147 L234 153" class="join-mark" />

        <g class="fusion-result">
          <path d="M293 136 H372 V158 H293 A11 11 0 0 1 282 147 A11 11 0 0 1 293 136 Z" class="chromosome-segment chromosome-segment--orange fusion-result-segment fusion-result-segment--orange" />
          <path d="M372 136 H451 A11 11 0 0 1 462 147 A11 11 0 0 1 451 158 H372 Z" class="chromosome-segment chromosome-segment--yellow fusion-result-segment fusion-result-segment--yellow" />
          <rect x="282" y="136" width="180" height="22" rx="11" class="chromosome-outline" />
          <path d="M372 133 V161" class="fusion-junction" />
        </g>
        <text x="372" y="178" class="node-label">{c.chromosome.joined}</text>
        <text x="372" y="194" class="micro-label">{c.chromosome.junction}</text>
        <text x="300" y="214" class="footer-label chromosome-note">{c.chromosome.holocentric}</text>
      </g>
    )}

    {kind === 'connectivity' && (
      <g class="diagram-scene connectivity-scene">
        <text x="115" y="18" class="group-label">{c.connectivity.populationA}</text>
        <text x="485" y="18" class="group-label">{c.connectivity.populationB}</text>

        <path d="M25 62 C28 31 67 23 108 27 C151 20 194 32 207 62 C218 91 187 116 146 115 C103 126 50 117 31 94 C21 83 20 72 25 62 Z" class="gene-patch gene-patch--a" />
        <path d="M393 62 C398 30 437 23 478 27 C521 20 564 33 576 62 C587 91 557 116 516 115 C473 126 420 117 401 94 C391 83 388 72 393 62 Z" class="gene-patch gene-patch--b" />

        {/* Population A contains the solid orange allele; population B initially contains only blue ring alleles. */}
        <g class="gene-population gene-population--a">
          <g class="gene-individual-wrap" transform="translate(66 57)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--orange" />
          </g>
          <g class="gene-individual-wrap" transform="translate(116 50)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(164 66)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--orange" />
          </g>
          <g class="gene-individual-wrap" transform="translate(91 94)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--orange" />
          </g>
          <g class="gene-individual-wrap" transform="translate(148 99)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
        </g>
        <g class="gene-population gene-population--b">
          <g class="gene-individual-wrap" transform="translate(430 55)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(480 48)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(533 62)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(446 96)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(497 95)">
            <circle r="14" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
          <g class="gene-individual-wrap" transform="translate(548 98)">
            <g class="recipient-offspring">
              <circle r="15" class="gene-individual gene-individual--offspring" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
            </g>
          </g>
        </g>

        {/* One individual moves; movement alone is not yet successful gene flow in this example. */}
        <path d="M188 55 C247 23 330 25 398 56" class="gene-route" marker-end={`url(#${id}-arrow)`} />
        <g class="gene-migrant-motion">
          <circle cx="294" cy="38" r="15" class="gene-individual gene-individual--migrant" />
          <circle cx="289" cy="38" r="3.5" class="allele-token allele-token--orange" />
          <circle cx="299" cy="38" r="3.5" class="allele-token allele-token--orange" />
        </g>
        <text x="294" y="76" class="micro-label gene-move-label">{c.connectivity.moves}</text>

        {/* Reproduction: the offspring receives one allele copy from each parent, not a blended colour. */}
        <g class="mating-parent mating-parent--migrant" transform="translate(238 153)">
          <g class="mating-parent-motion">
            <circle r="15" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--orange" />
          </g>
        </g>
        <text x="279" y="158" class="mating-plus">+</text>
        <g class="mating-parent mating-parent--resident" transform="translate(320 153)">
          <g class="mating-parent-motion">
            <circle r="15" class="gene-individual" /><circle cx="-5" r="3.5" class="allele-token allele-token--blue" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
        </g>
        <path d="M345 153 H386" class="gene-inheritance-arrow" marker-end={`url(#${id}-arrow)`} />
        <g class="gene-offspring-vignette" transform="translate(414 153)">
          <g class="gene-offspring-motion">
            <circle r="16" class="gene-individual gene-individual--offspring" /><circle cx="-5" r="3.5" class="allele-token allele-token--orange" /><circle cx="5" r="3.5" class="allele-token allele-token--blue" />
          </g>
        </g>
        <path d="M435 145 C474 124 505 117 535 111" class="gene-entry-route" marker-end={`url(#${id}-arrow)`} />
        <text x="279" y="187" class="micro-label gene-parent-label">{c.connectivity.parents}</text>
        <text x="435" y="178" class="micro-label gene-offspring-label">
          <tspan x="435">{c.connectivity.offspring}</tspan>
          <tspan x="435" dy="11">{c.connectivity.inheritance}</tspan>
        </text>
        <text x="500" y="130" class="micro-label gene-entry-label">{c.connectivity.enters}</text>
        <text x="300" y="213" class="footer-label gene-legend">{c.connectivity.legend}</text>
      </g>
    )}

    {kind === 'monitoring' && (
      <g class="diagram-scene monitoring-scene">
        <path d="M125 86 H170" class="flow workflow-link workflow-link--one" marker-end={`url(#${id}-arrow)`} />
        <path d="M275 86 H320" class="flow workflow-link workflow-link--two" marker-end={`url(#${id}-arrow)`} />
        <path d="M435 86 H478" class="flow workflow-link workflow-link--three" marker-end={`url(#${id}-arrow)`} />
        <g transform="translate(32 50)" class="workflow-stage workflow-stage--one">
          <rect width="92" height="72" rx="12" class="workflow-node" />
          <path d="M25 48 V25 M25 36 L16 29 M25 36 L34 29 M52 48 V20 M52 30 L43 23 M52 30 L61 23 M72 48 V29" class="icon-line" />
        </g>
        <g transform="translate(172 50)" class="workflow-stage workflow-stage--two">
          <rect width="104" height="72" rx="12" class="workflow-node" />
          <circle cx="47" cy="34" r="17" class="icon-line" />
          <path d="M60 47 L75 60 M39 34 H55 M47 26 V42" class="icon-line" />
        </g>
        <g transform="translate(322 50)" class="workflow-stage workflow-stage--three">
          <rect width="114" height="72" rx="12" class="workflow-node workflow-node--focus" />
          <path d="M22 48 C38 17 53 17 69 48 S100 79 106 38" class="icon-line" />
          <circle cx="36" cy="30" r="4" class="signal-dot" /><circle cx="86" cy="51" r="4" class="signal-dot" />
        </g>
        <g transform="translate(480 50)" class="workflow-stage workflow-stage--four">
          <rect width="88" height="72" rx="12" class="workflow-node" />
          <path d="M24 38 L39 53 L66 22" class="icon-line icon-line--strong" />
        </g>
        <text x="78" y="143" class="node-label">{c.monitoring.sample}</text>
        <text x="224" y="143" class="node-label">{c.monitoring.identify}</text>
        <text x="379" y="139" class="node-label">
          <tspan x="379">{c.monitoring.movement}</tspan>
          <tspan x="379" dy="13">{c.monitoring.candidates}</tspan>
        </text>
        <text x="524" y="143" class="node-label">{c.monitoring.validate}</text>
      </g>
    )}

    {kind === 'migration' && (
      <g class="diagram-scene migration-scene">
        <text x="78" y="26" class="group-label">{c.migration.sampling}</text>
        <circle cx="76" cy="70" r="22" class="sample-node migration-sample migration-sample--one" />
        <circle cx="76" cy="121" r="22" class="sample-node sample-node--alt migration-sample migration-sample--two" />
        <path d="M103 70 C180 18 243 29 292 75" class="relation migration-link migration-link--one" marker-end={`url(#${id}-arrow)`} />
        <path d="M103 121 C180 170 242 150 292 98" class="relation migration-link migration-link--two" marker-end={`url(#${id}-arrow)`} />
        <circle cx="325" cy="86" r="36" class="question-node migration-question" />
        <text x="325" y="92" class="question-mark">?</text>
        <path d="M363 86 C414 47 460 49 505 72" class="relation migration-link migration-link--three" marker-end={`url(#${id}-arrow)`} />
        <path d="M363 92 C414 132 460 129 505 108" class="relation migration-link migration-link--four" marker-end={`url(#${id}-arrow)`} />
        <circle cx="530" cy="70" r="20" class="sample-node migration-result migration-result--one" />
        <circle cx="530" cy="112" r="20" class="sample-node sample-node--alt migration-result migration-result--two" />
        <text x="325" y="142" class="node-label">{c.migration.origins}</text>
        <text x="455" y="153" class="node-label">{c.migration.routes}</text>
        <text x="300" y="178" class="footer-label">{c.migration.evidence}</text>
      </g>
    )}

    {kind === 'voucher' && (
      <g class="diagram-scene voucher-scene">
        {/* Specimen splits: wings to the envelope, body to the tube. */}
        <path d="M138 76 L262 54" class="vch-flow vch-flow--split" />
        <path d="M138 104 L262 122" class="vch-flow vch-flow--split" />
        {/* Both identifiers converge on one record row. */}
        <path d="M320 52 L448 82" class="vch-flow vch-flow--env" marker-end={`url(#${id}-arrow)`} />
        <path d="M320 122 L448 100" class="vch-flow vch-flow--tube" marker-end={`url(#${id}-arrow)`} />

        {/* Specimen: a bilaterally symmetric butterfly with ocelli. */}
        <g class="vch-specimen" transform="translate(86 90)">
          <rect x="-3" y="-24" width="6" height="48" rx="3" class="vch-body" />
          <path d="M-2 -24 C -8 -38 -15 -42 -20 -44 M2 -24 C 8 -38 15 -42 20 -44" class="vch-antenna" />
          <g class="vch-wings-l">
            <path d="M-4 -14 C -40 -34 -54 -18 -46 3 C -40 15 -17 12 -4 2 Z" class="vch-wing" />
            <path d="M-4 6 C -30 6 -40 20 -31 32 C -22 41 -8 32 -4 20 Z" class="vch-wing vch-wing--hind" />
            <circle cx="-27" cy="-6" r="4.5" class="vch-ocellus" />
          </g>
          <g class="vch-wings-r">
            <path d="M4 -14 C 40 -34 54 -18 46 3 C 40 15 17 12 4 2 Z" class="vch-wing" />
            <path d="M4 6 C 30 6 40 20 31 32 C 22 41 8 32 4 20 Z" class="vch-wing vch-wing--hind" />
            <circle cx="27" cy="-6" r="4.5" class="vch-ocellus" />
          </g>
          {/* Transient parts that fly to their stores during playback. */}
          <g class="vch-ghost-wings">
            <path d="M-2 -3 C -20 -17 -30 -5 -24 6 C -20 13 -6 11 -2 3 Z" class="vch-wing" />
            <path d="M2 -3 C 20 -17 30 -5 24 6 C 20 13 6 11 2 3 Z" class="vch-wing" />
          </g>
          <rect x="-2.5" y="-12" width="5" height="24" rx="2.5" class="vch-body vch-ghost-body" />
        </g>

        {/* Collector: a hand net that catches the specimen, then fades. */}
        <g class="vch-net" transform="translate(86 90)">
          <ellipse cx="0" cy="-2" rx="46" ry="48" class="vch-net-bag" />
          <path d="M-46 -12 A46 48 0 0 1 46 -12" class="vch-net-mesh" />
          <path d="M-40 -30 A46 48 0 0 1 40 -30 M-44 6 A46 48 0 0 0 44 6 M-30 -44 A46 48 0 0 1 30 -44" class="vch-net-mesh" />
          <path d="M-24 -46 V44 M0 -48 V48 M24 -46 V44" class="vch-net-mesh" />
          <ellipse cx="0" cy="-2" rx="46" ry="48" class="vch-net-hoop" />
          <path d="M32 40 L64 92" class="vch-net-handle" />
        </g>

        {/* Wings stored in a labelled envelope carrying the CAMID. */}
        <g class="vch-envelope" transform="translate(290 48)">
          <rect x="-28" y="-19" width="56" height="40" rx="3" class="vch-env" />
          <path d="M-28 -19 L0 -3 L28 -19" class="vch-env-flap" />
          <g class="vch-env-wings">
            <path d="M-1 3 C -15 -7 -23 1 -19 9 C -15 15 -5 13 -1 8 Z" class="vch-wing" />
            <path d="M1 3 C 15 -7 23 1 19 9 C 15 15 5 13 1 8 Z" class="vch-wing" />
          </g>
          <text x="0" y="-8" class="vch-idtag">{c.voucher.camid}</text>
        </g>

        {/* Body stored in a tube carrying its own tube ID (barcode). */}
        <g class="vch-tube-group" transform="translate(290 126)">
          <g class="vch-cap-group">
            <rect x="-12" y="-30" width="24" height="13" rx="4" class="vch-cap" />
            <rect x="-13" y="-19" width="26" height="5" rx="2" class="vch-cap" />
          </g>
          <rect x="-12" y="-14" width="24" height="48" rx="9" class="vch-tube" />
          <rect x="-12" y="-6" width="24" height="16" class="vch-label" />
          <path d="M-8 -3v10 M-5 -3v10 M-2 -3v10 M1 -3v10 M5 -3v10 M8 -3v10" class="vch-barcode" />
          <rect x="-3" y="16" width="6" height="14" rx="3" class="vch-body-inside" />
        </g>

        {/* Record: one row holds the CAMID and the tube ID together. */}
        <g class="vch-sheet-group" transform="translate(498 90)">
          <rect x="-46" y="-33" width="92" height="66" rx="6" class="vch-sheet" />
          <rect x="-46" y="-33" width="92" height="15" class="vch-sheet-head" />
          <rect x="-46" y="-3" width="92" height="16" class="vch-row-hit" />
          <path d="M0 -33V33 M-46 -18H46 M-46 -3H46 M-46 13H46" class="vch-grid" />
          <text x="-23" y="-22" class="vch-idtag">{c.voucher.camid}</text>
          <text x="23" y="-22" class="vch-idtag vch-idtag--sm">{c.voucher.tubeid}</text>
          <g class="vch-row-wing">
            <path d="M-25 5 C -33 -1 -37 3 -35 8 C -33 11 -28 10 -25 7 Z" class="vch-wing" />
            <path d="M-21 5 C -13 -1 -9 3 -11 8 C -13 11 -18 10 -21 7 Z" class="vch-wing" />
          </g>
          <path d="M13 1v8 M16 1v8 M19 1v8 M22 1v8 M26 1v8 M30 1v8" class="vch-barcode--row" />
          <path d="M-30 -11h20 M8 -11h12 M26 -11h14" class="vch-cell" />
          <path d="M-30 24h18 M6 24h16 M28 24h12" class="vch-cell" />
        </g>

        <text x="86" y="152" class="node-label">{c.voucher.specimen}</text>
        <text x="290" y="20" class="group-label">{c.voucher.envelope}</text>
        <text x="290" y="174" class="node-label">{c.voucher.tube}</text>
        <text x="498" y="152" class="node-label">{c.voucher.record}</text>
        <text x="300" y="188" class="footer-label">{c.voucher.link}</text>
      </g>
    )}
  </svg>

  <ol class="concept-mobile-flow" aria-label={k.title}>
    {mobileSteps.map((step, index) => (
      <li data-mobile-step>
        <span class="mobile-step-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        <span>{step}</span>
      </li>
    ))}
  </ol>
  <p class="concept-status" id={`${id}-status`} data-concept-status aria-live="polite">{c.ready}</p>
</figure>

<style>
  .concept-diagram {
    margin: 0;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--bg-inset);
  }
  .concept-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-s);
    padding: var(--space-s) var(--space-m);
    color: var(--text-strong);
    font-size: var(--step--1);
    border-bottom: 1px solid var(--hairline);
    background: color-mix(in oklab, var(--bg-panel) 76%, transparent);
  }
  .concept-title-group {
    display: grid;
    gap: 0.18rem;
    min-width: min(100%, 15rem);
  }
  .concept-kicker {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .concept-heading strong {
    display: block;
    font-weight: 620;
    font-size: var(--step-0);
    line-height: 1.25;
  }
  .concept-play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.45rem;
    padding: 0.52rem 0.82rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 12%, var(--bg-panel));
    color: var(--accent-strong);
    font: 650 var(--step--1)/1.1 var(--font-body);
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }
  .concept-play:hover {
    background: var(--accent);
    color: var(--bg);
    transform: translateY(-1px);
  }
  .concept-play:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .play-icon {
    display: inline-grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg-panel);
    font-size: 0.55rem;
    line-height: 1;
    text-indent: 0.08rem;
  }
  .concept-svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 12.5rem;
    color: var(--text-muted);
    padding-inline: var(--space-xs);
  }
  .group-label,
  .footer-label,
  .node-label,
  .micro-label {
    font-family: var(--font-mono);
    fill: var(--text-muted);
    text-anchor: middle;
  }
  .group-label { font-size: 12px; font-weight: 650; letter-spacing: 0.08em; text-transform: uppercase; fill: var(--accent-strong); }
  .node-label { font-size: 10.5px; }
  .micro-label { font-size: 9px; fill: var(--text-faint); }
  .footer-label { font-size: 11px; fill: var(--text-faint); }
  .flow,
  .relation,
  .icon-line {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .relation { stroke-dasharray: 5 5; stroke: var(--accent); }
  .arrowhead { fill: var(--accent); }
  .chromosome-segment { opacity: 0.94; }
  .chromosome-segment--orange { fill: var(--accent); }
  .chromosome-segment--yellow { fill: var(--highlight); }
  .chromosome-outline {
    fill: none;
    stroke: color-mix(in oklab, var(--text-strong) 54%, transparent);
    stroke-width: 1.2;
  }
  .breakpoint-line {
    fill: none;
    stroke: var(--bg-panel);
    stroke-width: 3;
    stroke-dasharray: 3 2;
  }
  .new-end {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 3;
    stroke-linecap: round;
  }
  .fusion-junction {
    fill: none;
    stroke: var(--bg-panel);
    stroke-width: 2.5;
    stroke-linecap: round;
  }
  .gene-patch {
    stroke-width: 1.5;
  }
  .gene-patch--a {
    fill: color-mix(in oklab, var(--c-burnt-500) 10%, transparent);
    stroke: color-mix(in oklab, var(--c-burnt-500) 74%, var(--text-muted));
  }
  .gene-patch--b {
    fill: color-mix(in oklab, var(--signal) 10%, transparent);
    stroke: color-mix(in oklab, var(--signal) 72%, var(--text-muted));
  }
  .gene-individual {
    fill: var(--bg-panel);
    stroke: var(--text-muted);
    stroke-width: 1.5;
  }
  .gene-individual--migrant,
  .gene-individual--offspring {
    stroke: var(--c-burnt-500);
    stroke-width: 2.2;
  }
  .allele-token { stroke-width: 1.6; }
  .allele-token--orange {
    fill: var(--c-burnt-500);
    stroke: var(--c-burnt-700);
  }
  .allele-token--blue {
    fill: var(--bg-panel);
    stroke: var(--signal);
    stroke-width: 2.2;
  }
  :global([data-mode='dark']) .allele-token--orange { fill: var(--c-burnt-300); stroke: var(--c-burnt-200); }
  :global([data-mode='light']) .allele-token--orange { fill: var(--c-burnt-700); stroke: var(--c-burnt-800); }
  .gene-route,
  .gene-inheritance-arrow,
  .gene-entry-route {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linecap: round;
  }
  .gene-route { stroke-dasharray: 7 6; }
  .gene-entry-route { stroke: var(--c-burnt-500); stroke-dasharray: 4 5; }
  .mating-plus {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 650;
    fill: var(--text-muted);
    text-anchor: middle;
  }
  .gene-entry-label { fill: color-mix(in oklab, var(--c-burnt-500) 75%, var(--text-muted)); }
  .signal-dot { fill: var(--highlight); }
  .workflow-node {
    fill: var(--bg-panel);
    stroke: var(--hairline-strong);
    stroke-width: 1.5;
  }
  .workflow-node--focus { stroke: var(--accent); }
  .icon-line--strong { stroke: var(--accent-strong); stroke-width: 3; }
  .sample-node {
    fill: color-mix(in oklab, var(--accent) 16%, var(--bg-panel));
    stroke: var(--accent);
    stroke-width: 2;
  }
  .sample-node--alt {
    fill: color-mix(in oklab, var(--highlight) 18%, var(--bg-panel));
    stroke: var(--highlight-strong);
  }
  .question-node {
    fill: var(--bg-panel);
    stroke: var(--accent);
    stroke-width: 2;
  }
  .question-mark {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 650;
    fill: var(--accent-strong);
    text-anchor: middle;
  }
  .event-ring {
    fill: color-mix(in oklab, var(--highlight) 12%, transparent);
    stroke: var(--highlight-strong);
    stroke-width: 1.5;
    opacity: 0.6;
  }
  .split-mark,
  .join-mark {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* The final scientific state is visible before and after playback. Motion
     appears only after the visitor explicitly presses the play control. */
  .concept-diagram.is-playing .play-icon { animation: play-orbit 900ms ease-in-out infinite; }
  .concept-diagram.is-playing .process-line,
  .concept-diagram.is-playing .workflow-link,
  .concept-diagram.is-playing .relation { stroke-dasharray: 10 8; }
  .concept-diagram.is-playing .fission-source { animation: chromosome-source-focus 850ms ease-out both; }
  .concept-diagram.is-playing .breakpoint-line { animation: breakpoint-flash 800ms 420ms ease-out both; }
  .concept-diagram.is-playing .process-line--one { animation: draw-link 700ms 620ms ease-out both; }
  .concept-diagram.is-playing .event-ring--one,
  .concept-diagram.is-playing .split-mark { animation: event-pop 620ms 900ms var(--ease-settle) both; }
  .concept-diagram.is-playing .fission-product--orange { animation: fission-left 950ms 1.18s var(--ease-settle) both; }
  .concept-diagram.is-playing .fission-product--yellow { animation: fission-right 950ms 1.18s var(--ease-settle) both; }
  .concept-diagram.is-playing .new-end { animation: end-stabilise 620ms 1.72s var(--ease-settle) both; }
  .concept-diagram.is-playing .fusion-source--orange { animation: fusion-input-orange 1.05s 2.35s ease-in-out both; }
  .concept-diagram.is-playing .fusion-source--yellow { animation: fusion-input-yellow 1.05s 2.35s ease-in-out both; }
  .concept-diagram.is-playing .process-line--two { animation: draw-link 650ms 2.95s ease-out both; }
  .concept-diagram.is-playing .event-ring--two,
  .concept-diagram.is-playing .join-mark { animation: event-pop 620ms 3.2s var(--ease-settle) both; }
  .concept-diagram.is-playing .fusion-result-segment--orange { animation: fuse-orange 900ms 3.5s var(--ease-settle) both; }
  .concept-diagram.is-playing .fusion-result-segment--yellow { animation: fuse-yellow 900ms 3.5s var(--ease-settle) both; }
  .concept-diagram.is-playing .fusion-result .chromosome-outline { animation: joined-outline 600ms 3.82s ease-out both; }
  .concept-diagram.is-playing .fusion-junction { animation: junction-flash 720ms 3.92s var(--ease-settle) both; }

  .concept-diagram.is-playing .gene-population--a { animation: population-focus 700ms 0s ease-out both; }
  .concept-diagram.is-playing .gene-population--b { animation: population-focus 700ms 240ms ease-out both; }
  .concept-diagram.is-playing .gene-route { animation: gene-route-draw 700ms 520ms ease-out both; }
  .concept-diagram.is-playing .gene-migrant-motion { animation: gene-migrate 1.4s 760ms ease-in-out both; }
  .concept-diagram.is-playing .gene-move-label { animation: label-focus 760ms 1.1s ease-out both; }
  .concept-diagram.is-playing .mating-parent--migrant .mating-parent-motion { animation: parent-migrant 1.05s 2.12s ease-in-out both; }
  .concept-diagram.is-playing .mating-parent--resident .mating-parent-motion { animation: parent-resident 1.05s 2.12s ease-in-out both; }
  .concept-diagram.is-playing .gene-parent-label { animation: stage-label-focus 700ms 2.18s ease-out both; }
  .concept-diagram.is-playing .mating-plus { animation: event-pop 620ms 2.58s var(--ease-settle) both; }
  .concept-diagram.is-playing .gene-inheritance-arrow { animation: gene-route-draw 620ms 2.84s ease-out both; }
  .concept-diagram.is-playing .gene-offspring-motion { animation: offspring-inherit 820ms 3.22s var(--ease-settle) both; }
  .concept-diagram.is-playing .gene-offspring-label { animation: stage-label-focus 700ms 3.28s ease-out both; }
  .concept-diagram.is-playing .gene-entry-route { animation: gene-route-draw 620ms 3.72s ease-out both; }
  .concept-diagram.is-playing .recipient-offspring { animation: recipient-allele 780ms 4.08s var(--ease-settle) both; }
  .concept-diagram.is-playing .gene-entry-label { animation: stage-label-focus 700ms 4.15s ease-out both; }

  .concept-diagram.is-playing .workflow-stage--one { animation: group-focus 720ms 0s var(--ease-settle) both; }
  .concept-diagram.is-playing .workflow-link--one { animation: draw-link 650ms 620ms ease-out both; }
  .concept-diagram.is-playing .workflow-stage--two { animation: group-focus 720ms 1.05s var(--ease-settle) both; }
  .concept-diagram.is-playing .workflow-link--two { animation: draw-link 650ms 1.65s ease-out both; }
  .concept-diagram.is-playing .workflow-stage--three { animation: group-focus 720ms 2.1s var(--ease-settle) both; }
  .concept-diagram.is-playing .workflow-link--three { animation: draw-link 650ms 2.75s ease-out both; }
  .concept-diagram.is-playing .workflow-stage--four { animation: group-focus 820ms 3.2s var(--ease-settle) both; }

  .concept-diagram.is-playing .migration-sample--one { animation: stage-focus 720ms 0s var(--ease-settle) both; }
  .concept-diagram.is-playing .migration-sample--two { animation: stage-focus 720ms 280ms var(--ease-settle) both; }
  .concept-diagram.is-playing .migration-link--one,
  .concept-diagram.is-playing .migration-link--two { animation: route-flow 1.1s 820ms linear both; }
  .concept-diagram.is-playing .migration-question { animation: question-focus 900ms 1.7s var(--ease-settle) both; }
  .concept-diagram.is-playing .migration-link--three,
  .concept-diagram.is-playing .migration-link--four { animation: route-flow 1.1s 2.35s linear both; }
  .concept-diagram.is-playing .migration-result--one { animation: stage-focus 720ms 3.15s var(--ease-settle) both; }
  .concept-diagram.is-playing .migration-result--two { animation: stage-focus 720ms 3.45s var(--ease-settle) both; }

  .concept-status {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 0 var(--space-m) var(--space-s);
    color: var(--text-faint);
    font: 500 var(--step--2)/1.3 var(--font-mono);
    letter-spacing: 0.04em;
  }
  .concept-status::before {
    content: '';
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: var(--hairline-strong);
  }
  .concept-diagram.is-playing .concept-status::before {
    background: var(--highlight);
    box-shadow: 0 0 0 0.28rem color-mix(in oklab, var(--highlight) 18%, transparent);
  }
  .concept-diagram.is-finished .concept-status::before { background: var(--accent); }

  @keyframes play-orbit { 50% { transform: rotate(180deg) scale(1.08); } 100% { transform: rotate(360deg); } }
  @keyframes chromosome-source-focus { 0% { opacity: 0.3; filter: saturate(0.55); } 65% { opacity: 1; filter: saturate(1.25) brightness(1.08); } 100% { opacity: 1; filter: none; } }
  @keyframes breakpoint-flash { 0% { opacity: 0; stroke-width: 1; } 55% { opacity: 1; stroke-width: 5; } 100% { opacity: 1; stroke-width: 3; } }
  @keyframes draw-link { from { opacity: 0; stroke-dashoffset: 48; } to { opacity: 1; stroke-dashoffset: 0; } }
  @keyframes event-pop { 0% { opacity: 0; transform: scale(0.25); } 65% { opacity: 1; transform: scale(1.25); } 100% { opacity: 0.85; transform: scale(1); } }
  @keyframes fission-left { from { opacity: 0; transform: translateX(14px); } 70% { opacity: 1; transform: translateX(-2px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes fission-right { from { opacity: 0; transform: translateX(-14px); } 70% { opacity: 1; transform: translateX(2px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes end-stabilise { from { opacity: 0; stroke-width: 1; } 65% { opacity: 1; stroke-width: 5; } to { opacity: 1; stroke-width: 3; } }
  @keyframes fusion-input-orange { 0% { opacity: 0; transform: translateX(0); } 12%, 62% { opacity: 1; transform: translateX(0); } 100% { opacity: 0.22; transform: translateX(10px); } }
  @keyframes fusion-input-yellow { 0% { opacity: 0; transform: translateX(0); } 12%, 62% { opacity: 1; transform: translateX(0); } 100% { opacity: 0.22; transform: translateX(-10px); } }
  @keyframes fuse-orange { from { opacity: 0; transform: translateX(-18px); } 70% { opacity: 1; transform: translateX(2px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes fuse-yellow { from { opacity: 0; transform: translateX(18px); } 70% { opacity: 1; transform: translateX(-2px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes joined-outline { from { opacity: 0; } to { opacity: 1; } }
  @keyframes junction-flash { from { opacity: 0; stroke-width: 1; } 55% { opacity: 1; stroke-width: 5; } to { opacity: 1; stroke-width: 2.5; } }
  @keyframes group-focus { from { opacity: 0.12; filter: saturate(0.45) brightness(0.72); } 70% { opacity: 1; filter: saturate(1.25) brightness(1.12); } to { opacity: 1; filter: none; } }
  @keyframes route-flow { from { opacity: 0.15; stroke-dashoffset: 72; } to { opacity: 1; stroke-dashoffset: 0; } }
  @keyframes population-focus { from { opacity: 0.18; filter: saturate(0.5) brightness(0.75); } 70% { opacity: 1; filter: saturate(1.25) brightness(1.08); } to { opacity: 1; filter: none; } }
  @keyframes gene-route-draw { from { opacity: 0; stroke-dasharray: 64; stroke-dashoffset: 64; } to { opacity: 1; stroke-dasharray: 7 6; stroke-dashoffset: 0; } }
