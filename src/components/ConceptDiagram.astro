  /* Voucher scene: specimen → wings in an envelope (CAMID) + body in a tube (tube ID) → one record row. */
  .vch-body { fill: var(--text-muted); }
  .vch-antenna { fill: none; stroke: var(--text-muted); stroke-width: 2; stroke-linecap: round; }
  .vch-wing { fill: color-mix(in oklab, var(--accent) 22%, var(--bg-panel)); stroke: var(--accent); stroke-width: 1.5; }
  .vch-wing--hind { fill: color-mix(in oklab, var(--accent) 14%, var(--bg-panel)); }
