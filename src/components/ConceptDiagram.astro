<script>
  const conceptTimers = new WeakMap<HTMLElement, number>();

  function initConceptDiagrams() {
    document.querySelectorAll<HTMLElement>('[data-concept-diagram]').forEach((diagram) => {
      if (diagram.dataset.conceptInit === '1') return;
      diagram.dataset.conceptInit = '1';

      const button = diagram.querySelector<HTMLButtonElement>('[data-concept-play]');
      const label = diagram.querySelector<HTMLElement>('[data-concept-play-label]');
      const status = diagram.querySelector<HTMLElement>('[data-concept-status]');
      if (!button || !label || !status) return;

      button.addEventListener('click', () => {
        const runningTimer = conceptTimers.get(diagram);
        if (runningTimer !== undefined) window.clearTimeout(runningTimer);

        diagram.classList.remove('is-playing', 'is-finished');
        // Restart the keyframe timeline when Replay is pressed.
        void diagram.offsetWidth;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          diagram.classList.add('is-finished');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          return;
        }

        diagram.classList.add('is-playing');
        diagram.setAttribute('aria-busy', 'true');
        status.textContent = diagram.dataset.labelPlaying ?? '';
        label.textContent = diagram.dataset.labelReplay ?? '';

        const timer = window.setTimeout(() => {
          diagram.classList.remove('is-playing');
          diagram.classList.add('is-finished');
          diagram.setAttribute('aria-busy', 'false');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          conceptTimers.delete(diagram);
        }, 5000);
        conceptTimers.set(diagram, timer);
      });
    });
  }

  document.addEventListener('astro:page-load', initConceptDiagrams);
  initConceptDiagrams();
</script>
