  .concept-diagram.is-playing .vch-flow--env,
  .concept-diagram.is-playing .vch-flow--tube { stroke-dasharray: 48; }
  /* 1. A collector's net swoops in and catches the specimen, then fades. */
  .concept-diagram.is-playing .vch-net { animation: net-catch 1.35s 0s ease-in-out both; }
  /* 2. The specimen is opened and filed: wings → envelope, body → tube. */
  .concept-diagram.is-playing .voucher-scene .vch-wings-l { animation: wing-open 600ms 1.05s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-wings-r { animation: wing-open 600ms 1.15s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-ghost-wings { animation: fly-wings 1.15s 1.15s ease-in-out both; }
  .concept-diagram.is-playing .vch-ghost-body { animation: fly-body 1.15s 1.2s ease-in-out both; }
  .concept-diagram.is-playing .vch-cap-group { animation: cap-open 1s 1.7s ease-in-out both; }
  .concept-diagram.is-playing .vch-envelope { animation: group-focus 700ms 2.05s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-env-wings { animation: event-pop 620ms 2.2s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-tube-group { animation: group-focus 700ms 2.2s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-body-inside { animation: event-pop 620ms 2.4s var(--ease-settle) both; }
  /* 3. Both identifiers converge on one record row. */
  .concept-diagram.is-playing .vch-flow--env { animation: draw-link 650ms 3.0s ease-out both; }
  .concept-diagram.is-playing .vch-flow--tube { animation: draw-link 650ms 3.2s ease-out both; }
  .concept-diagram.is-playing .vch-sheet-group { animation: group-focus 720ms 3.55s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-row-hit { animation: row-mark 760ms 3.8s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-row-wing,
  .concept-diagram.is-playing .voucher-scene .vch-barcode--row { animation: event-pop 620ms 4.05s var(--ease-settle) both; }

