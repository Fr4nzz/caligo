  .vch-barcode--row,
  .vch-net { transform-box: fill-box; transform-origin: center; }
  .vch-wings-l { transform-origin: right center; }
  .vch-wings-r { transform-origin: left center; }
  .vch-row-hit { transform-origin: left center; }
  .vch-net { transform-origin: 72% 92%; }

  .concept-diagram.is-playing .vch-flow--env,
  .concept-diagram.is-playing .vch-flow--tube { stroke-dasharray: 48; }
  /* 1. A collector's net swoops in and catches the specimen, then fades. */
  .concept-diagram.is-playing .vch-net { animation: net-catch 1.35s 0s ease-in-out both; }
  /* 2. The specimen is opened and filed: wings → envelope, body → tube. */
  .concept-diagram.is-playing .voucher-scene .vch-wings-l { animation: wing-open 600ms 1.05s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-wings-r { animation: wing-open 600ms 1.15s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-ghost-wings { animation: fly-wings 1.15s 1.15s ease-in-out both; }
  .concept-diagram.is-playing .vch-ghost-body { animation: fly-body 1.15s 1.2s ease-in-out both; }
  .concept-diagram.is-playing .vch-cap-group { animation: cap-open 1s 1.7s ease-in-out both; }
  .concept-diagram.is-playing .vch-envelope { animation: group-focus 700ms 2.05s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-env-wings { animation: event-pop 620ms 2.2s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-tube-group { animation: group-focus 700ms 2.2s var(--ease-settle) both; }
  .concept-diagram.is-playing .vch-body-inside { animation: event-pop 620ms 2.4s var(--ease-settle) both; }
  /* 3. Both identifiers converge on one record row. */
  .concept-diagram.is-playing .vch-flow--env { animation: draw-link 650ms 3.0s ease-out both; }
  .concept-diagram.is-playing .vch-flow--tube { animation: draw-link 650ms 3.2s ease-out both; }
  .concept-diagram.is-playing .vch-sheet-group { animation: group-focus 720ms 3.55s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-row-hit { animation: row-mark 760ms 3.8s var(--ease-settle) both; }
  .concept-diagram.is-playing .voucher-scene .vch-row-wing,
  .concept-diagram.is-playing .voucher-scene .vch-barcode--row { animation: event-pop 620ms 4.05s var(--ease-settle) both; }

  @keyframes net-catch {
    0% { opacity: 0; transform: translate(-64px, -52px) rotate(-34deg); }
    22% { opacity: 0.95; }
    46% { opacity: 0.95; transform: translate(0, 0) rotate(0deg); }
    70% { opacity: 0.95; transform: translate(0, 0) rotate(0deg); }
    100% { opacity: 0; transform: translate(10px, -6px) rotate(6deg); }
  }
  @keyframes wing-open { from { opacity: 0.2; transform: scaleX(0.12); } 70% { opacity: 1; transform: scaleX(1.06); } to { opacity: 1; transform: scaleX(1); } }
  @keyframes fly-wings { 0% { opacity: 0; transform: translate(0, 0) scale(1); } 18% { opacity: 0.9; } 82% { opacity: 0.9; } 100% { opacity: 0; transform: translate(204px, -42px) scale(0.42); } }
  @keyframes fly-body { 0% { opacity: 0; transform: translate(0, 0) scale(1); } 18% { opacity: 0.9; } 82% { opacity: 0.9; } 100% { opacity: 0; transform: translate(204px, 36px) scale(0.5); } }
  @keyframes cap-open { 0% { transform: translateY(0); } 25%, 70% { transform: translateY(-12px); } 100% { transform: translateY(0); } }
  @keyframes row-mark { from { opacity: 0; transform: scaleX(0.15); } 70% { opacity: 1; transform: scaleX(1.03); } to { opacity: 1; transform: scaleX(1); } }
  [data-context='pilot'] .concept-heading { padding-block-start: var(--space-xs); }
  [data-context='pilot'] .concept-svg { max-height: 10.75rem; }
  .concept-mobile-flow { display: none; }
  @media (max-width: 34rem) {
    .concept-heading { display: grid; }
    .concept-play { width: 100%; }
    .concept-svg {
      display: block;
      width: 100%;
      max-height: none;
      padding: var(--space-xs) 0 0;
    }
    .concept-svg .group-label,
    .concept-svg .node-label,
    .concept-svg .footer-label { display: none; }
    .connectivity-scene .micro-label { display: none; }
    .concept-mobile-flow {
      display: grid;
      list-style: none;
      margin: 0;
      padding: var(--space-s) var(--space-m) var(--space-m);
    }
    .concept-mobile-flow li {
      position: relative;
      display: grid;
      grid-template-columns: 2.35rem minmax(0, 1fr);
      align-items: center;
      gap: var(--space-xs);
      min-height: 3.25rem;
      color: var(--text);
      font-size: var(--step--1);
      line-height: 1.4;
    }
    .concept-mobile-flow li:not(:last-child)::after {
      content: '';
      position: absolute;
      left: 1.08rem;
      top: 2.6rem;
      bottom: -0.65rem;
      width: 1px;
      background: var(--hairline-strong);
    }
    .mobile-step-number {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid var(--accent);
      border-radius: 50%;
      background: var(--bg-panel);
      color: var(--accent-strong);
      font-family: var(--font-mono);
      font-size: var(--step--2);
      font-weight: 650;
    }
    .concept-diagram.is-playing .concept-mobile-flow li {
      animation: mobile-step 620ms var(--ease-settle) both;
    }
    .concept-diagram.is-playing .concept-mobile-flow li:nth-child(2) { animation-delay: 900ms; }
    .concept-diagram.is-playing .concept-mobile-flow li:nth-child(3) { animation-delay: 1.8s; }
    .concept-diagram.is-playing .concept-mobile-flow li:nth-child(4) { animation-delay: 2.7s; }
    .concept-diagram.is-playing .concept-mobile-flow li:nth-child(5) { animation-delay: 3.5s; }
    @keyframes mobile-step {
      from { opacity: 0.28; transform: translateX(-0.6rem); }
      70% { opacity: 1; transform: translateX(0.18rem); }
      to { opacity: 1; transform: translateX(0); }
