  .vch-net-mesh { fill: none; stroke: var(--hairline-strong); stroke-width: 0.8; opacity: 0.7; }
  .vch-net-handle { fill: none; stroke: var(--accent-strong); stroke-width: 4; stroke-linecap: round; }
  .vch-env { fill: color-mix(in oklab, var(--accent) 6%, var(--bg-panel)); stroke: var(--hairline-strong); stroke-width: 1.5; }
  .vch-env-flap { fill: none; stroke: var(--hairline-strong); stroke-width: 1.2; }
