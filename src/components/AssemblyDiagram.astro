    padding: 0.48rem var(--space-m) 0.58rem;
    border-top: 1px solid var(--hairline);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    line-height: 1.35;
  }

  @media (max-width: 38rem) {
    .assembly-heading { display: grid; }
    .assembly-play { width: 100%; }
    .assembly-svg {
      max-height: none;
      padding-top: var(--space-xs);
    }
    .assembly-svg .asm-stage-label,
    .assembly-svg .asm-gap-label,
    .assembly-svg .asm-hic-action,
    .assembly-svg .asm-assessment-label,
    .assembly-svg .asm-summary,
    .assembly-svg .asm-disclaimer { display: none; }
    .assembly-mobile-flow {
