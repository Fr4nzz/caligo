---
import { getDict, type Locale } from '../i18n';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const c = getDict(locale).home.journey.assemblyDiagram;
const id = `assembly-journey-${locale}`;
const mobileSteps = [
  c.reads,
  `${c.contigs} + ${c.ordering}`,
  `${c.chromosomes} · ${c.gap}`,
  `${c.assessment}: ${c.continuity} · ${c.completeness} · ${c.limits}`,
] as const;
---

<figure
  class="assembly-diagram"
  data-assembly-diagram
  data-label-play={c.play}
  data-label-replay={c.replay}
  data-label-playing={c.playing}
  data-label-finished={c.finished}
  data-label-reduced={c.reduced}
  aria-busy="false"
>
  <figcaption class="assembly-heading">
    <span class="assembly-title-group">
      <span class="assembly-kicker">{c.conceptual}</span>
      <strong>{c.title}</strong>
    </span>
    <button type="button" class="assembly-play" data-assembly-play aria-describedby={`${id}-status`}>
      <span class="assembly-play-icon" aria-hidden="true">▶</span>
      <span data-assembly-play-label>{c.play}</span>
    </button>
  </figcaption>

  <svg class="assembly-svg" viewBox="0 0 720 270" role="img" aria-labelledby={`${id}-title ${id}-desc`}>
    <title id={`${id}-title`}>{c.title}</title>
    <desc id={`${id}-desc`}>{c.description}</desc>
    <defs>
      <marker id={`${id}-arrow`} viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" class="asm-arrowhead" />
      </marker>
      <pattern id={`${id}-gap`} width="6" height="6" patternUnits="userSpaceOnUse">
        <path d="M0 6 L6 0" class="asm-gap-hatch" />
      </pattern>
    </defs>

    <g class="asm-stage asm-stage--reads">
      <path d="M18 38 H158" class="asm-stage-rule" />
      <text x="88" y="27" class="asm-stage-label">{c.reads}</text>
      <rect x="24" y="58" width="70" height="10" rx="5" class="asm-read asm-read--one" />
      <rect x="68" y="75" width="72" height="10" rx="5" class="asm-read asm-read--two" />
      <rect x="37" y="92" width="63" height="10" rx="5" class="asm-read asm-read--three" />
      <rect x="84" y="109" width="61" height="10" rx="5" class="asm-read asm-read--four" />
      <rect x="20" y="126" width="78" height="10" rx="5" class="asm-read asm-read--five" />
      <rect x="59" y="143" width="84" height="10" rx="5" class="asm-read asm-read--six" />
      <path d="M68 80 H94 M84 114 H100 M59 148 H98" class="asm-overlap" />
    </g>

    <path d="M164 106 H188" class="asm-flow asm-flow--one" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--contigs">
      <path d="M195 38 H323" class="asm-stage-rule" />
      <text x="259" y="27" class="asm-stage-label">{c.contigs}</text>
      <rect x="201" y="66" width="108" height="15" rx="7.5" class="asm-contig asm-contig--one" />
      <rect x="211" y="101" width="96" height="15" rx="7.5" class="asm-contig asm-contig--two" />
      <rect x="198" y="136" width="114" height="15" rx="7.5" class="asm-contig asm-contig--three" />
      <path d="M215 73 H232 M247 73 H276 M286 73 H300 M225 108 H251 M264 108 H294 M212 143 H239 M252 143 H280 M292 143 H303" class="asm-contig-bands" />
    </g>

    <path d="M324 106 H348" class="asm-flow asm-flow--two" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--chromosomes">
      <path d="M354 38 H522" class="asm-stage-rule" />
      <text x="438" y="27" class="asm-stage-label">{c.chromosomes}</text>

      <g class="asm-unit asm-unit--one">
        <rect x="362" y="61" width="48" height="17" rx="8.5" class="asm-unit-segment" />
        <path d="M411 69.5 H424" class="asm-order-link" />
        <rect x="425" y="61" width="83" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <rect x="362" y="61" width="146" height="17" rx="8.5" class="asm-unit-outline" />
      </g>

      <g class="asm-unit asm-unit--two">
        <rect x="362" y="99" width="64" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <rect x="426" y="99" width="15" height="17" class="asm-gap" fill={`url(#${id}-gap)`} />
        <rect x="441" y="99" width="67" height="17" rx="8.5" class="asm-unit-segment" />
        <rect x="362" y="99" width="146" height="17" rx="8.5" class="asm-unit-outline" />
        <path d="M433.5 87 V96" class="asm-gap-pointer" />
        <text x="433.5" y="84" class="asm-gap-label">{c.gap}</text>
      </g>

      <g class="asm-unit asm-unit--three">
        <rect x="362" y="137" width="37" height="17" rx="8.5" class="asm-unit-segment" />
        <path d="M400 145.5 H414" class="asm-order-link" />
        <rect x="415" y="137" width="93" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <rect x="362" y="137" width="146" height="17" rx="8.5" class="asm-unit-outline" />
      </g>
      <text x="435" y="176" class="asm-order-label">{c.ordering}</text>
    </g>

    <path d="M525 106 H548" class="asm-flow asm-flow--three" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--assessment">
      <rect x="554" y="38" width="150" height="165" rx="8" class="asm-assessment-card" />
      <text x="629" y="57" class="asm-stage-label">{c.assessment}</text>

      <g class="asm-assessment-units" aria-hidden="true">
        <rect x="570" y="70" width="117" height="7" rx="3.5" class="asm-mini-unit" />
        <rect x="570" y="84" width="47" height="7" rx="3.5" class="asm-mini-unit asm-mini-unit--alt" />
        <rect x="625" y="84" width="62" height="7" rx="3.5" class="asm-mini-unit" />
        <rect x="570" y="98" width="117" height="7" rx="3.5" class="asm-mini-unit asm-mini-unit--alt" />
      </g>
      <path d="M568 114 H690" class="asm-scan-line" />

      <g class="asm-check asm-check--continuity">
        <circle cx="576" cy="135" r="7" class="asm-check-ring" />
        <path d="M572 135 L575 138 L581 131" class="asm-check-mark" />
        <text x="590" y="139" class="asm-assessment-label">{c.continuity}</text>
      </g>
      <g class="asm-check asm-check--completeness">
        <circle cx="576" cy="157" r="7" class="asm-check-ring" />
        <path d="M572 157 L575 160 L581 153" class="asm-check-mark" />
        <text x="590" y="161" class="asm-assessment-label">{c.completeness}</text>
      </g>
      <g class="asm-check asm-check--limits">
        <circle cx="576" cy="179" r="7" class="asm-limit-ring" />
        <path d="M576 175 V180 M576 184 V184.5" class="asm-limit-mark" />
        <text x="590" y="183" class="asm-assessment-label">{c.limits}</text>
      </g>
    </g>

    <text x="360" y="225" class="asm-summary">{c.summary}</text>
    <text x="360" y="250" class="asm-disclaimer">{c.disclaimer}</text>
  </svg>

  <ol class="assembly-mobile-flow" aria-label={c.title}>
    {mobileSteps.map((step, index) => (
      <li>
        <span class="assembly-step-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        <span>{step}</span>
      </li>
    ))}
  </ol>

  <p class="assembly-status" id={`${id}-status`} data-assembly-status aria-live="polite">{c.ready}</p>
</figure>

<style>
  .assembly-diagram {
    margin: 0;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--bg-inset);
  }

  .assembly-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-s);
    padding: var(--space-xs) var(--space-m) var(--space-s);
    color: var(--text-strong);
    border-bottom: 1px solid var(--hairline);
    background: color-mix(in oklab, var(--bg-panel) 76%, transparent);
  }

  .assembly-title-group {
    display: grid;
    gap: 0.18rem;
    min-width: min(100%, 15rem);
  }

  .assembly-kicker {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .assembly-heading strong {
    display: block;
    font-size: var(--step-0);
    font-weight: 620;
    line-height: 1.25;
  }

  .assembly-play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    padding: 0.52rem 0.82rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 12%, var(--bg-panel));
    color: var(--accent-strong);
    font: 650 var(--step--1)/1.1 var(--font-body);
    cursor: pointer;
    transition: background var(--dur-quick) var(--ease-glide), color var(--dur-quick) var(--ease-glide), transform var(--dur-quick) var(--ease-glide);
  }

  .assembly-play:hover {
    background: var(--accent);
    color: var(--accent-contrast);
    transform: translateY(-1px);
  }

  .assembly-play:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .assembly-play-icon {
    display: inline-grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 0.55rem;
    line-height: 1;
    text-indent: 0.08rem;
  }

  .assembly-svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 15.5rem;
    padding: var(--space-xs) var(--space-xs) 0;
  }

  .asm-stage-label,
  .asm-gap-label,
  .asm-order-label,
  .asm-assessment-label,
  .asm-summary,
  .asm-disclaimer {
    font-family: var(--font-mono);
    fill: var(--text-muted);
  }

  .asm-stage-label {
    font-size: 10px;
    font-weight: 650;
    letter-spacing: 0.055em;
    text-anchor: middle;
    text-transform: uppercase;
    fill: var(--accent-strong);
  }

  .asm-stage-rule {
    fill: none;
    stroke: var(--hairline-strong);
    stroke-width: 1;
  }

  .asm-read {
    fill: color-mix(in oklab, var(--signal) 24%, var(--bg-panel));
    stroke: color-mix(in oklab, var(--signal) 72%, var(--text-muted));
    stroke-width: 1.4;
  }

  .asm-read:nth-of-type(even) {
    fill: color-mix(in oklab, var(--accent) 18%, var(--bg-panel));
    stroke: var(--accent);
  }

  .asm-overlap {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 2.4;
    stroke-linecap: round;
    opacity: 0.9;
  }

  .asm-flow {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 1.7;
    stroke-linecap: round;
  }

  .asm-arrowhead { fill: var(--accent); }

  .asm-contig {
    fill: color-mix(in oklab, var(--accent) 28%, var(--bg-panel));
    stroke: var(--accent);
    stroke-width: 1.5;
  }

  .asm-contig--two {
    fill: color-mix(in oklab, var(--highlight) 24%, var(--bg-panel));
    stroke: var(--highlight-strong);
  }

  .asm-contig-bands {
    fill: none;
    stroke: color-mix(in oklab, var(--text-strong) 70%, transparent);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .asm-unit-segment {
    fill: var(--accent);
  }

  .asm-unit-segment--alt {
    fill: color-mix(in oklab, var(--highlight) 74%, var(--accent));
  }

  .asm-unit-outline {
    fill: none;
    stroke: color-mix(in oklab, var(--text-strong) 58%, transparent);
    stroke-width: 1.2;
  }

  .asm-order-link {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 1.7;
    stroke-dasharray: 3 3;
  }

  .asm-gap {
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-hatch {
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-pointer {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-label,
  .asm-order-label {
    font-size: 8.5px;
    text-anchor: middle;
    fill: var(--text-faint);
  }

  .asm-assessment-card {
    fill: var(--bg-panel);
    stroke: var(--hairline-strong);
    stroke-width: 1.4;
  }

  .asm-mini-unit {
    fill: color-mix(in oklab, var(--accent) 66%, var(--bg-panel));
  }

  .asm-mini-unit--alt {
    fill: color-mix(in oklab, var(--highlight) 64%, var(--bg-panel));
  }

  .asm-scan-line {
    fill: none;
    stroke: var(--signal);
    stroke-width: 2.2;
    stroke-linecap: round;
  }

  .asm-check-ring,
  .asm-limit-ring {
    fill: color-mix(in oklab, var(--accent) 12%, var(--bg-panel));
    stroke: var(--accent-strong);
    stroke-width: 1.4;
  }

  .asm-limit-ring {
    fill: color-mix(in oklab, var(--highlight) 12%, var(--bg-panel));
    stroke: var(--highlight-strong);
  }

  .asm-check-mark,
  .asm-limit-mark {
    fill: none;
    stroke: var(--accent-strong);
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .asm-limit-mark { stroke: var(--highlight-strong); }

  .asm-assessment-label {
    font-size: 9.5px;
    font-weight: 550;
    text-anchor: start;
  }

  .asm-summary {
    font-size: 10px;
    text-anchor: middle;
    fill: var(--text-muted);
  }

  .asm-disclaimer {
    font-size: 8.5px;
    text-anchor: middle;
    fill: var(--text-faint);
  }

  .asm-read,
  .asm-contig,
  .asm-unit,
  .asm-check,
  .asm-assessment-card {
    transform-box: fill-box;
    transform-origin: center;
  }

  .asm-contig { transform-origin: left center; }

  .assembly-diagram.is-playing .assembly-play-icon {
    animation: assembly-control 620ms var(--ease-settle) both;
  }

  .assembly-diagram.is-playing .asm-read--one { animation: read-align 620ms 0ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--two { animation: read-align 620ms 60ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--three { animation: read-align 620ms 120ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--four { animation: read-align 620ms 180ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--five { animation: read-align 620ms 240ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--six { animation: read-align 620ms 300ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-overlap { animation: overlap-focus 720ms 380ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--one { animation: assembly-link 520ms 760ms ease-out both; }
  .assembly-diagram.is-playing .asm-contig--one { animation: contig-build 680ms 1.02s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-contig--two { animation: contig-build 680ms 1.14s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-contig--three { animation: contig-build 680ms 1.26s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--two { animation: assembly-link 520ms 1.74s ease-out both; }
  .assembly-diagram.is-playing .asm-order-link { animation: order-link 620ms 2.04s ease-out both; }
  .assembly-diagram.is-playing .asm-unit--one { animation: unit-settle 680ms 2.18s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-unit--two { animation: unit-settle 680ms 2.3s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-unit--three { animation: unit-settle 680ms 2.42s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-gap { animation: gap-focus 780ms 2.65s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-gap-pointer,
  .assembly-diagram.is-playing .asm-gap-label { animation: label-reveal 540ms 2.82s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--three { animation: assembly-link 520ms 3.08s ease-out both; }
  .assembly-diagram.is-playing .asm-assessment-card { animation: assessment-focus 620ms 3.28s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-scan-line { animation: assessment-scan 760ms 3.48s ease-out both; }
  .assembly-diagram.is-playing .asm-check--continuity { animation: check-reveal 520ms 3.82s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-check--completeness { animation: check-reveal 520ms 4.08s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-check--limits { animation: check-reveal 520ms 4.34s var(--ease-settle) both; }

  @keyframes assembly-control {
    from { opacity: 0.55; transform: scale(0.94); }
    70% { opacity: 1; transform: scale(1.05); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes read-align {
    from { opacity: 0.36; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes overlap-focus {
    from { opacity: 0.2; stroke-dasharray: 1 14; }
    to { opacity: 0.9; stroke-dasharray: 28 0; }
  }

  @keyframes assembly-link {
    from { opacity: 0.25; stroke-dasharray: 30; stroke-dashoffset: 30; }
    to { opacity: 1; stroke-dasharray: 30; stroke-dashoffset: 0; }
  }

  @keyframes contig-build {
    from { opacity: 0.3; transform: scaleX(0.22); }
    to { opacity: 1; transform: scaleX(1); }
  }

  @keyframes order-link {
    from { opacity: 0.25; stroke-dashoffset: 18; }
    to { opacity: 1; stroke-dashoffset: 0; }
  }

  @keyframes unit-settle {
    from { opacity: 0.25; transform: translateX(-12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes gap-focus {
    from { opacity: 0.25; }
    55% { opacity: 1; }
    to { opacity: 0.78; }
  }

  @keyframes label-reveal {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes assessment-focus {
    from { opacity: 0.45; }
    to { opacity: 1; }
  }

  @keyframes assessment-scan {
    from { opacity: 0.25; stroke-dasharray: 122; stroke-dashoffset: 122; }
    78% { opacity: 1; stroke-dashoffset: 0; }
    to { opacity: 0.55; stroke-dasharray: 122; stroke-dashoffset: 0; }
  }

  @keyframes check-reveal {
    from { opacity: 0.2; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .assembly-mobile-flow { display: none; }

  .assembly-status {
    margin: 0;
    padding: 0.48rem var(--space-m) 0.58rem;
    border-top: 1px solid var(--hairline);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    line-height: 1.35;
  }

  @media (max-width: 38rem) {
    .assembly-heading { display: grid; }
    .assembly-play { width: 100%; }
    .assembly-svg {
      max-height: none;
      padding-top: var(--space-xs);
    }
    .assembly-svg .asm-stage-label,
    .assembly-svg .asm-gap-label,
    .assembly-svg .asm-order-label,
    .assembly-svg .asm-assessment-label,
    .assembly-svg .asm-summary,
    .assembly-svg .asm-disclaimer { display: none; }
    .assembly-mobile-flow {
      display: grid;
      list-style: none;
      margin: 0;
      padding: var(--space-s) var(--space-m) var(--space-m);
    }
    .assembly-mobile-flow li {
      position: relative;
      display: grid;
      grid-template-columns: 2.35rem minmax(0, 1fr);
      align-items: center;
      gap: var(--space-xs);
      min-height: 3.25rem;
      color: var(--text);
      font-size: var(--step--1);
      line-height: 1.4;
    }
    .assembly-mobile-flow li:not(:last-child)::after {
      content: '';
      position: absolute;
      left: 1.08rem;
      top: 2.6rem;
      bottom: -0.65rem;
      width: 1px;
      background: var(--hairline-strong);
    }
    .assembly-step-number {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid var(--accent);
      border-radius: 50%;
      background: var(--bg-panel);
      color: var(--accent-strong);
      font-family: var(--font-mono);
      font-size: var(--step--2);
      font-weight: 650;
    }
    .assembly-diagram.is-playing .assembly-mobile-flow li {
      animation: mobile-assembly-step 560ms var(--ease-settle) both;
    }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(2) { animation-delay: 1.05s; }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(3) { animation-delay: 2.15s; }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(4) { animation-delay: 3.35s; }
  }

  @keyframes mobile-assembly-step {
    from { opacity: 0.35; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .assembly-play,
    .assembly-play:hover {
      transition: none;
      transform: none;
    }
    .assembly-diagram *,
    .assembly-diagram *::before,
    .assembly-diagram *::after {
      animation: none !important;
    }
  }
</style>

<script>
  const assemblyTimers = new WeakMap<HTMLElement, number>();

  function initAssemblyDiagrams() {
    document.querySelectorAll<HTMLElement>('[data-assembly-diagram]').forEach((diagram) => {
      if (diagram.dataset.assemblyInit === '1') return;
      diagram.dataset.assemblyInit = '1';

      const button = diagram.querySelector<HTMLButtonElement>('[data-assembly-play]');
      const label = diagram.querySelector<HTMLElement>('[data-assembly-play-label]');
      const status = diagram.querySelector<HTMLElement>('[data-assembly-status]');
      if (!button || !label || !status) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        diagram.classList.add('is-reduced');
        status.textContent = diagram.dataset.labelReduced ?? '';
      }

      button.addEventListener('click', () => {
        const runningTimer = assemblyTimers.get(diagram);
        if (runningTimer !== undefined) window.clearTimeout(runningTimer);

        diagram.classList.remove('is-playing', 'is-finished');
        void diagram.offsetWidth;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          diagram.classList.add('is-finished');
          diagram.setAttribute('aria-busy', 'false');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          return;
        }

        diagram.classList.add('is-playing');
        diagram.setAttribute('aria-busy', 'true');
        status.textContent = diagram.dataset.labelPlaying ?? '';
        label.textContent = diagram.dataset.labelReplay ?? '';

        const timer = window.setTimeout(() => {
          diagram.classList.remove('is-playing');
          diagram.classList.add('is-finished');
          diagram.setAttribute('aria-busy', 'false');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          assemblyTimers.delete(diagram);
        }, 5000);
        assemblyTimers.set(diagram, timer);
      });
    });
  }

  document.addEventListener('astro:page-load', initAssemblyDiagrams);
  initAssemblyDiagrams();
</script>
