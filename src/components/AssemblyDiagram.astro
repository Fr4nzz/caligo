---
import { getDict, type Locale } from '../i18n';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
const c = getDict(locale).home.journey.assemblyDiagram;
const id = `assembly-journey-${locale}`;
const mobileSteps = [
  c.reads,
  c.contigs,
  `${c.hic}: ${c.hicAction}`,
  `${c.chromosomes} · ${c.gap}`,
  `${c.assessment}: ${c.continuity} · ${c.completeness} · ${c.limits}`,
] as const;
---

<figure
  class="assembly-diagram"
  data-assembly-diagram
  data-label-play={c.play}
  data-label-replay={c.replay}
  data-label-playing={c.playing}
  data-label-finished={c.finished}
  data-label-reduced={c.reduced}
  aria-busy="false"
>
  <figcaption class="assembly-heading">
    <span class="assembly-title-group">
      <span class="assembly-kicker">{c.conceptual}</span>
      <strong>{c.title}</strong>
    </span>
    <button type="button" class="assembly-play" data-assembly-play aria-describedby={`${id}-status`}>
      <span class="assembly-play-icon" aria-hidden="true">▶</span>
      <span data-assembly-play-label>{c.play}</span>
    </button>
  </figcaption>

  <svg class="assembly-svg" viewBox="0 0 760 280" role="img" aria-labelledby={`${id}-title ${id}-desc`}>
    <title id={`${id}-title`}>{c.title}</title>
    <desc id={`${id}-desc`}>{c.description}</desc>
    <defs>
      <marker id={`${id}-arrow`} viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" class="asm-arrowhead" />
      </marker>
      <pattern id={`${id}-gap`} width="6" height="6" patternUnits="userSpaceOnUse">
        <path d="M0 6 L6 0" class="asm-gap-hatch" />
      </pattern>
    </defs>

    <g class="asm-stage asm-stage--reads">
      <path d="M16 42 H130" class="asm-stage-rule" />
      <text x="73" y="30" class="asm-stage-label">{c.reads}</text>
      <rect x="20" y="60" width="55" height="9" rx="4.5" class="asm-read asm-read--one" />
      <rect x="50" y="75" width="66" height="9" rx="4.5" class="asm-read asm-read--two" />
      <rect x="30" y="90" width="50" height="9" rx="4.5" class="asm-read asm-read--three" />
      <rect x="70" y="105" width="50" height="9" rx="4.5" class="asm-read asm-read--four" />
      <rect x="18" y="120" width="62" height="9" rx="4.5" class="asm-read asm-read--five" />
      <rect x="52" y="135" width="68" height="9" rx="4.5" class="asm-read asm-read--six" />
      <path d="M50 79.5 H75 M70 109.5 H80 M52 139.5 H80" class="asm-overlap" />
    </g>

    <path d="M132 103 H151" class="asm-flow asm-flow--one" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--contigs">
      <path d="M154 42 H278" class="asm-stage-rule" />
      <text x="216" y="30" class="asm-stage-label">{c.contigs}</text>
      <rect x="160" y="68" width="108" height="14" rx="7" class="asm-contig asm-contig--one" />
      <rect x="168" y="101" width="98" height="14" rx="7" class="asm-contig asm-contig--two" />
      <rect x="157" y="134" width="116" height="14" rx="7" class="asm-contig asm-contig--three" />
      <path d="M174 75 H192 M207 75 H236 M247 75 H260 M182 108 H208 M221 108 H253 M171 141 H198 M211 141 H239 M251 141 H264" class="asm-contig-bands" />
    </g>

    <path d="M280 103 H296" class="asm-flow asm-flow--two" marker-end={`url(#${id}-arrow)`} />

    {/* Hi-C supplies long-range contact evidence for grouping, ordering and orienting contigs. */}
    <g class="asm-stage asm-stage--hic">
      <path d="M299 42 H392" class="asm-stage-rule" />
      <text x="345.5" y="30" class="asm-stage-label">{c.hic}</text>
      <g class="asm-hic-contact-map" aria-hidden="true">
        <rect x="316" y="57" width="59" height="59" rx="4" class="asm-hic-map-shell" />
        <path d="M330.75 58 V115 M345.5 58 V115 M360.25 58 V115 M317 71.75 H374 M317 86.5 H374 M317 101.25 H374" class="asm-hic-grid" />
        <rect x="320" y="61" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--strong asm-hic-contact--one" />
        <rect x="333" y="74" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--strong asm-hic-contact--two" />
        <rect x="348" y="89" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--strong asm-hic-contact--three" />
        <rect x="361" y="102" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--strong asm-hic-contact--four" />
        <rect x="361" y="61" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--long asm-hic-contact--five" />
        <rect x="320" y="102" width="10" height="10" rx="2" class="asm-hic-contact asm-hic-contact--long asm-hic-contact--six" />
        <path d="M318 114 L373 59" class="asm-hic-scan" />
      </g>
      <text x="345.5" y="138" class="asm-hic-action">{c.hicAction}</text>
    </g>

    <path d="M394 103 H411" class="asm-flow asm-flow--three" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--chromosomes">
      <path d="M414 42 H566" class="asm-stage-rule" />
      <text x="490" y="30" class="asm-stage-label asm-stage-label--wide">{c.chromosomes}</text>

      <g class="asm-unit asm-unit--one">
        <rect x="420" y="61" width="48" height="17" rx="8.5" class="asm-unit-segment" />
        <rect x="468" y="61" width="88" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <path d="M468 63 V76" class="asm-unit-join" />
        <rect x="420" y="61" width="136" height="17" rx="8.5" class="asm-unit-outline" />
      </g>

      <g class="asm-unit asm-unit--two">
        <rect x="420" y="99" width="58" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <rect x="478" y="99" width="15" height="17" class="asm-gap" fill={`url(#${id}-gap)`} />
        <rect x="493" y="99" width="63" height="17" rx="8.5" class="asm-unit-segment" />
        <rect x="420" y="99" width="136" height="17" rx="8.5" class="asm-unit-outline" />
        <path d="M485.5 87 V96" class="asm-gap-pointer" />
        <text x="485.5" y="84" class="asm-gap-label">{c.gap}</text>
      </g>

      <g class="asm-unit asm-unit--three">
        <rect x="420" y="137" width="37" height="17" rx="8.5" class="asm-unit-segment" />
        <rect x="457" y="137" width="99" height="17" rx="8.5" class="asm-unit-segment asm-unit-segment--alt" />
        <path d="M457 139 V152" class="asm-unit-join" />
        <rect x="420" y="137" width="136" height="17" rx="8.5" class="asm-unit-outline" />
      </g>
    </g>

    <path d="M568 103 H585" class="asm-flow asm-flow--four" marker-end={`url(#${id}-arrow)`} />

    <g class="asm-stage asm-stage--assessment">
      <rect x="590" y="40" width="154" height="164" rx="8" class="asm-assessment-card" />
      <text x="667" y="59" class="asm-stage-label">{c.assessment}</text>

      <g class="asm-assessment-units" aria-hidden="true">
        <rect x="606" y="72" width="120" height="7" rx="3.5" class="asm-mini-unit" />
        <rect x="606" y="86" width="48" height="7" rx="3.5" class="asm-mini-unit asm-mini-unit--alt" />
        <rect x="662" y="86" width="64" height="7" rx="3.5" class="asm-mini-unit" />
        <rect x="606" y="100" width="120" height="7" rx="3.5" class="asm-mini-unit asm-mini-unit--alt" />
      </g>
      <path d="M604 116 H730" class="asm-scan-line" />

      <g class="asm-check asm-check--continuity">
        <circle cx="612" cy="137" r="7" class="asm-check-ring" />
        <path d="M608 137 L611 140 L617 133" class="asm-check-mark" />
        <text x="626" y="141" class="asm-assessment-label">{c.continuity}</text>
      </g>
      <g class="asm-check asm-check--completeness">
        <circle cx="612" cy="159" r="7" class="asm-check-ring" />
        <path d="M608 159 L611 162 L617 155" class="asm-check-mark" />
        <text x="626" y="163" class="asm-assessment-label">{c.completeness}</text>
      </g>
      <g class="asm-check asm-check--limits">
        <circle cx="612" cy="181" r="7" class="asm-limit-ring" />
        <path d="M612 177 V182 M612 186 V186.5" class="asm-limit-mark" />
        <text x="626" y="185" class="asm-assessment-label">{c.limits}</text>
      </g>
    </g>

    <text x="380" y="238" class="asm-summary">{c.summary}</text>
    <text x="380" y="262" class="asm-disclaimer">{c.disclaimer}</text>
  </svg>

  <ol class="assembly-mobile-flow" aria-label={c.title}>
    {mobileSteps.map((step, index) => (
      <li>
        <span class="assembly-step-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        <span>{step}</span>
      </li>
    ))}
  </ol>

  <p class="assembly-status" id={`${id}-status`} data-assembly-status aria-live="polite">{c.ready}</p>
</figure>

<style>
  .assembly-diagram {
    margin: 0;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--bg-inset);
  }

  .assembly-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-s);
    padding: var(--space-xs) var(--space-m) var(--space-s);
    color: var(--text-strong);
    border-bottom: 1px solid var(--hairline);
    background: color-mix(in oklab, var(--bg-panel) 76%, transparent);
  }

  .assembly-title-group {
    display: grid;
    gap: 0.18rem;
    min-width: min(100%, 15rem);
  }

  .assembly-kicker {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .assembly-heading strong {
    display: block;
    font-size: var(--step-0);
    font-weight: 620;
    line-height: 1.25;
  }

  .assembly-play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    padding: 0.52rem 0.82rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 12%, var(--bg-panel));
    color: var(--accent-strong);
    font: 650 var(--step--1)/1.1 var(--font-body);
    cursor: pointer;
    transition: background var(--dur-quick) var(--ease-glide), color var(--dur-quick) var(--ease-glide), transform var(--dur-quick) var(--ease-glide);
  }

  .assembly-play:hover {
    background: var(--accent);
    color: var(--accent-contrast);
    transform: translateY(-1px);
  }

  .assembly-play:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .assembly-play-icon {
    display: inline-grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 0.55rem;
    line-height: 1;
    text-indent: 0.08rem;
  }

  .assembly-svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 15.5rem;
    padding: var(--space-xs) var(--space-xs) 0;
  }

  .asm-stage-label,
  .asm-gap-label,
  .asm-hic-action,
  .asm-assessment-label,
  .asm-summary,
  .asm-disclaimer {
    font-family: var(--font-mono);
    fill: var(--text-muted);
  }

  .asm-stage-label {
    font-size: 10px;
    font-weight: 650;
    letter-spacing: 0.055em;
    text-anchor: middle;
    text-transform: uppercase;
    fill: var(--accent-strong);
  }

  .asm-stage-label--wide { font-size: 8.5px; }

  .asm-stage-rule {
    fill: none;
    stroke: var(--hairline-strong);
    stroke-width: 1;
  }

  .asm-read {
    fill: color-mix(in oklab, var(--signal) 24%, var(--bg-panel));
    stroke: color-mix(in oklab, var(--signal) 72%, var(--text-muted));
    stroke-width: 1.4;
  }

  .asm-read:nth-of-type(even) {
    fill: color-mix(in oklab, var(--accent) 18%, var(--bg-panel));
    stroke: var(--accent);
  }

  .asm-overlap {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 2.4;
    stroke-linecap: round;
    opacity: 0.9;
  }

  .asm-flow {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 1.7;
    stroke-linecap: round;
  }

  .asm-arrowhead { fill: var(--accent); }

  .asm-contig {
    fill: color-mix(in oklab, var(--accent) 28%, var(--bg-panel));
    stroke: var(--accent);
    stroke-width: 1.5;
  }

  .asm-contig--two {
    fill: color-mix(in oklab, var(--highlight) 24%, var(--bg-panel));
    stroke: var(--highlight-strong);
  }

  .asm-contig-bands {
    fill: none;
    stroke: color-mix(in oklab, var(--text-strong) 70%, transparent);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .asm-hic-map-shell {
    fill: var(--bg-panel);
    stroke: var(--hairline-strong);
    stroke-width: 1.4;
  }

  .asm-hic-grid {
    fill: none;
    stroke: var(--hairline-strong);
    stroke-width: 0.8;
    opacity: 0.55;
  }

  .asm-hic-contact {
    fill: color-mix(in oklab, var(--accent) 72%, var(--bg-panel));
    stroke: var(--accent-strong);
    stroke-width: 0.7;
  }

  .asm-hic-contact--long {
    fill: color-mix(in oklab, var(--signal) 34%, var(--bg-panel));
    stroke: color-mix(in oklab, var(--signal) 76%, var(--text-muted));
  }

  .asm-hic-scan {
    fill: none;
    stroke: var(--signal);
    stroke-width: 1.7;
    stroke-linecap: round;
  }

  .asm-hic-action {
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 550;
    text-anchor: middle;
    fill: var(--text-faint);
  }

  .asm-unit-segment {
    fill: var(--accent);
  }

  .asm-unit-segment--alt {
    fill: color-mix(in oklab, var(--highlight) 74%, var(--accent));
  }

  .asm-unit-outline {
    fill: none;
    stroke: color-mix(in oklab, var(--text-strong) 58%, transparent);
    stroke-width: 1.2;
  }

  .asm-unit-join {
    fill: none;
    stroke: color-mix(in oklab, var(--bg-panel) 72%, transparent);
    stroke-width: 1.2;
  }

  .asm-gap {
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-hatch {
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-pointer {
    fill: none;
    stroke: var(--highlight-strong);
    stroke-width: 1;
  }

  .asm-gap-label {
    font-size: 8.5px;
    text-anchor: middle;
    fill: var(--text-faint);
  }

  .asm-assessment-card {
    fill: var(--bg-panel);
    stroke: var(--hairline-strong);
    stroke-width: 1.4;
  }

  .asm-mini-unit {
    fill: color-mix(in oklab, var(--accent) 66%, var(--bg-panel));
  }

  .asm-mini-unit--alt {
    fill: color-mix(in oklab, var(--highlight) 64%, var(--bg-panel));
  }

  .asm-scan-line {
    fill: none;
    stroke: var(--signal);
    stroke-width: 2.2;
    stroke-linecap: round;
  }

  .asm-check-ring,
  .asm-limit-ring {
    fill: color-mix(in oklab, var(--accent) 12%, var(--bg-panel));
    stroke: var(--accent-strong);
    stroke-width: 1.4;
  }

  .asm-limit-ring {
    fill: color-mix(in oklab, var(--highlight) 12%, var(--bg-panel));
    stroke: var(--highlight-strong);
  }

  .asm-check-mark,
  .asm-limit-mark {
    fill: none;
    stroke: var(--accent-strong);
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .asm-limit-mark { stroke: var(--highlight-strong); }

  .asm-assessment-label {
    font-size: 9.5px;
    font-weight: 550;
    text-anchor: start;
  }

  .asm-summary {
    font-size: 10px;
    text-anchor: middle;
    fill: var(--text-muted);
  }

  .asm-disclaimer {
    font-size: 8.5px;
    text-anchor: middle;
    fill: var(--text-faint);
  }

  .asm-read,
  .asm-contig,
  .asm-hic-map-shell,
  .asm-hic-contact,
  .asm-unit,
  .asm-check,
  .asm-assessment-card {
    transform-box: fill-box;
    transform-origin: center;
  }

  .asm-contig { transform-origin: left center; }

  .assembly-diagram.is-playing .assembly-play-icon {
    animation: assembly-control 620ms var(--ease-settle) both;
  }

  .assembly-diagram.is-playing .asm-read--one { animation: read-align 620ms 0ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--two { animation: read-align 620ms 60ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--three { animation: read-align 620ms 120ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--four { animation: read-align 620ms 180ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--five { animation: read-align 620ms 240ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-read--six { animation: read-align 620ms 300ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-overlap { animation: overlap-focus 720ms 380ms var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--one { animation: assembly-link 520ms 760ms ease-out both; }
  .assembly-diagram.is-playing .asm-contig--one { animation: contig-build 680ms 1.02s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-contig--two { animation: contig-build 680ms 1.14s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-contig--three { animation: contig-build 680ms 1.26s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--two { animation: assembly-link 520ms 1.7s ease-out both; }
  .assembly-diagram.is-playing .asm-hic-map-shell { animation: hic-map-focus 600ms 1.92s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-contact--one { animation: hic-contact-pop 430ms 2.02s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-contact--two { animation: hic-contact-pop 430ms 2.1s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-contact--three { animation: hic-contact-pop 430ms 2.18s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-contact--four { animation: hic-contact-pop 430ms 2.26s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-contact--five,
  .assembly-diagram.is-playing .asm-hic-contact--six { animation: hic-contact-pop 430ms 2.34s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-hic-scan { animation: hic-scan 680ms 2.2s ease-out both; }
  .assembly-diagram.is-playing .asm-hic-action { animation: label-reveal 500ms 2.48s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--three { animation: assembly-link 520ms 2.72s ease-out both; }
  .assembly-diagram.is-playing .asm-unit--one { animation: unit-settle 680ms 3s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-unit--two { animation: unit-settle 680ms 3.12s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-unit--three { animation: unit-settle 680ms 3.24s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-gap { animation: gap-focus 780ms 3.38s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-gap-pointer,
  .assembly-diagram.is-playing .asm-gap-label { animation: label-reveal 540ms 3.52s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-flow--four { animation: assembly-link 520ms 3.74s ease-out both; }
  .assembly-diagram.is-playing .asm-assessment-card { animation: assessment-focus 620ms 3.94s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-scan-line { animation: assessment-scan 760ms 4.14s ease-out both; }
  .assembly-diagram.is-playing .asm-check--continuity { animation: check-reveal 520ms 4.48s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-check--completeness { animation: check-reveal 520ms 4.74s var(--ease-settle) both; }
  .assembly-diagram.is-playing .asm-check--limits { animation: check-reveal 520ms 5s var(--ease-settle) both; }

  @keyframes assembly-control {
    from { opacity: 0.55; transform: scale(0.94); }
    70% { opacity: 1; transform: scale(1.05); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes read-align {
    from { opacity: 0.36; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes overlap-focus {
    from { opacity: 0.2; stroke-dasharray: 1 14; }
    to { opacity: 0.9; stroke-dasharray: 28 0; }
  }

  @keyframes assembly-link {
    from { opacity: 0.25; stroke-dasharray: 30; stroke-dashoffset: 30; }
    to { opacity: 1; stroke-dasharray: 30; stroke-dashoffset: 0; }
  }

  @keyframes contig-build {
