    }
    .assembly-diagram *,
    .assembly-diagram *::before,
    .assembly-diagram *::after {
      animation: none !important;
    }
  }
</style>

<script>
  const assemblyTimers = new WeakMap<HTMLElement, number>();

  function initAssemblyDiagrams() {
    document.querySelectorAll<HTMLElement>('[data-assembly-diagram]').forEach((diagram) => {
      if (diagram.dataset.assemblyInit === '1') return;
      diagram.dataset.assemblyInit = '1';

      const button = diagram.querySelector<HTMLButtonElement>('[data-assembly-play]');
      const label = diagram.querySelector<HTMLElement>('[data-assembly-play-label]');
      const status = diagram.querySelector<HTMLElement>('[data-assembly-status]');
      if (!button || !label || !status) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        diagram.classList.add('is-reduced');
        status.textContent = diagram.dataset.labelReduced ?? '';
      }

      button.addEventListener('click', () => {
        const runningTimer = assemblyTimers.get(diagram);
        if (runningTimer !== undefined) window.clearTimeout(runningTimer);

        diagram.classList.remove('is-playing', 'is-finished');
        void diagram.offsetWidth;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          diagram.classList.add('is-finished');
          diagram.setAttribute('aria-busy', 'false');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          return;
        }

        diagram.classList.add('is-playing');
        diagram.setAttribute('aria-busy', 'true');
        status.textContent = diagram.dataset.labelPlaying ?? '';
        label.textContent = diagram.dataset.labelReplay ?? '';

        const timer = window.setTimeout(() => {
          diagram.classList.remove('is-playing');
          diagram.classList.add('is-finished');
          diagram.setAttribute('aria-busy', 'false');
          status.textContent = diagram.dataset.labelFinished ?? '';
          label.textContent = diagram.dataset.labelReplay ?? '';
          assemblyTimers.delete(diagram);
        }, 5800);
        assemblyTimers.set(diagram, timer);
      });
    });
  }

  document.addEventListener('astro:page-load', initAssemblyDiagrams);
  initAssemblyDiagrams();
</script>
