      animation: mobile-assembly-step 560ms var(--ease-settle) both;
    }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(2) { animation-delay: 0.95s; }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(3) { animation-delay: 1.85s; }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(4) { animation-delay: 2.85s; }
    .assembly-diagram.is-playing .assembly-mobile-flow li:nth-child(5) { animation-delay: 4.05s; }
