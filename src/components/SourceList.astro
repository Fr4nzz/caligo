---
import { getDict, type Locale } from '../i18n';
import { SOURCES, type Source } from '../data/records';
import SourceRef from './SourceRef.astro';

interface Props {
  readonly ids: string[];
  readonly locale: Locale;
}

const { ids, locale } = Astro.props;
const sd = getDict(locale).sourceDrawer;

const sourceMap = new Map(SOURCES.map((s) => [s.id, s]));
const entries = ids
  .map((id) => sourceMap.get(id))
  .filter((s): s is Source => s !== undefined);
---

{entries.length > 0 && (
  <section class="source-list" aria-labelledby="source-list-heading">
    <h2 id="source-list-heading" class="source-list-heading mono">
      {sd.open}
    </h2>
    <ol class="source-list-ol">
      {entries.map((source) => (
        <SourceRef source={source} locale={locale} />
      ))}
    </ol>
  </section>
)}

<style>
  .source-list {
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid var(--hairline-strong);
  }
  .source-list-heading {
    margin: 0 0 var(--space-s);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .source-list-ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }
</style>
