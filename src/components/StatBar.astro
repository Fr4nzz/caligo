---
import CardIcon, { type CardIconName } from './CardIcon.astro';

type MetricKind = 'participants' | 'facilities' | 'countries' | 'pilots';

interface Metric {
  readonly value: number | string;
  readonly label: string;
  readonly asOf?: string;
  readonly kind?: MetricKind;
}

interface Props {
  readonly metrics: readonly Metric[];
  readonly variant?: 'bar' | 'community-cards';
}

const { metrics, variant = 'bar' } = Astro.props;
const iconByKind: Record<MetricKind, CardIconName> = {
  participants: 'people',
  facilities: 'facility',
  countries: 'globe',
  pilots: 'project',
};
---

{metrics.length >= 2 && variant === 'community-cards' && (
  <ul class="metric-cards" role="list">
    {metrics.map((metric) => (
      <li class:list={['metric-card', { 'metric-card--lead': metric.kind === 'participants' }]}>
        <strong class="metric-card__value">{metric.value}</strong>
        <span class="metric-card__copy">
          <span class="metric-card__label">{metric.label}</span>
          {metric.asOf && <span class="metric-card__asof">{metric.asOf}</span>}
        </span>
        {metric.kind && <CardIcon name={iconByKind[metric.kind]} class="metric-card__icon" />}
      </li>
    ))}
  </ul>
)}

{metrics.length >= 2 && variant === 'bar' && (
  <ul class="stat-bar" role="list">
    {metrics.map((metric) => (
      <li class="stat-item">
        <span class="stat-value">{metric.value}</span>
        <span class="stat-label mono">{metric.label}</span>
        {metric.asOf && <span class="stat-asof mono">{metric.asOf}</span>}
      </li>
    ))}
  </ul>
)}

<style>
  .metric-cards {
    display: grid;
    grid-template-columns: 1.3fr repeat(3, minmax(0, 1fr));
    gap: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .metric-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 0.875rem;
    min-width: 0;
    min-height: 6.75rem;
    padding: 1.125rem;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: linear-gradient(145deg, var(--bg-panel), var(--bg-inset));
  }
  .metric-card--lead {
    border-color: color-mix(in oklab, var(--accent) 48%, var(--hairline));
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--accent) 8%, var(--bg-panel)),
      color-mix(in oklab, var(--accent) 17%, var(--bg-inset))
    );
    box-shadow: inset 3px 0 0 var(--accent);
  }
  .metric-card__value {
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 620;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.05em;
    line-height: 0.82;
  }
  .metric-card--lead .metric-card__value {
    color: var(--accent-strong);
    font-size: var(--step-4);
  }
  .metric-card__copy {
    align-self: center;
    min-width: 0;
  }
  .metric-card__label {
    display: block;
    overflow-wrap: anywhere;
    color: var(--text-strong);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 700;
    letter-spacing: 0.075em;
    line-height: 1.28;
    text-transform: uppercase;
  }
  .metric-card__asof {
    display: block;
    margin-top: 0.375rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
    line-height: 1.25;
  }


  .stat-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m) var(--space-l);
    list-style: none;
    margin: 0;
    padding: var(--space-m);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--bg-panel);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .stat-value {
    color: var(--text-strong);
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 560;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.018em;
    line-height: 1;
  }
  .stat-label {
    color: var(--text-faint);
    font-size: var(--step--2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .stat-asof {
    color: var(--text-faint);
    font-size: var(--step--2);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  @media (max-width: 50rem) {
    .metric-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
    }
    .metric-card {
      min-height: 6rem;
      column-gap: 0.45rem;
      padding: 0.7rem;
    }
    .metric-card__value {
      font-size: var(--step-2);
    }
    .metric-card--lead .metric-card__value {
      font-size: var(--step-3);
    }
    .metric-card__label {
      font-size: 0.56rem;
      letter-spacing: 0.035em;
    }
    .metric-card--lead .metric-card__label {
      font-size: 0.56rem;
      letter-spacing: 0.025em;
      white-space: nowrap;
    }
    .metric-card__asof {
      margin-top: 0.25rem;
      font-size: 0.5rem;
      white-space: nowrap;
    }

  }

  @media (max-width: 22rem) {
    .metric-cards {
      grid-template-columns: 1fr;
    }
    .metric-card {
      min-height: 5rem;
    }
    .metric-card__label,
    .metric-card--lead .metric-card__label {
      font-size: var(--step--2);
      white-space: normal;
    }
    .metric-card__asof {
      font-size: var(--step--2);
    }
  }
</style>
