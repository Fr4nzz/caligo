---
import { getDict, type Locale } from '../i18n';
import type { Source } from '../data/records';

interface Props {
  readonly source: Source;
  readonly locale: Locale;
}

const { source, locale } = Astro.props;
const sd = getDict(locale).sourceDrawer;

const linkHref = source.url;
const linkLabel = source.doi ? `DOI: ${source.doi}` : source.url;

const dateLabel = (source.kind === 'database' || source.kind === 'institutional')
  ? sd.databaseAccessed
  : sd.checkedDate;
---

<li id={`source-${source.id}`} class="src-entry">
  <p class="src-citation">{source.citation}</p>
  <p class="src-meta mono">
    {source.kind === 'preprint' && (
      <span class="src-flag">{sd.preprint}</span>
    )}
    {(source.kind === 'database' || source.kind === 'institutional') && (
      <span class="src-flag">{sd.mutableData}</span>
    )}
    <span class="src-date">
      <span class="src-date-label">{dateLabel}:</span>
      {' '}{source.checkedDate}
    </span>
    {' '}
    <a
      class="src-link"
      href={linkHref}
      target="_blank"
      rel="noopener noreferrer external"
    >
      {linkLabel}
    </a>
  </p>
</li>

<style>
  .src-entry {
    padding-block: var(--space-s);
    border-bottom: 1px solid var(--hairline);
    list-style: none;
  }
  .src-entry:last-child {
    border-bottom: none;
  }
  .src-citation {
    margin: 0 0 0.35rem;
    font-size: var(--step--1);
    color: var(--text);
    line-height: 1.55;
  }
  .src-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.8rem;
    font-size: var(--step--2);
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
  .src-flag {
    color: var(--text-muted);
    font-style: italic;
    flex: 0 0 100%;
  }
  .src-date {
    white-space: nowrap;
  }
  .src-date-label {
    color: var(--text-muted);
  }
  .src-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-color: color-mix(in oklab, var(--accent) 35%, transparent);
    word-break: break-all;
  }
  .src-link:hover {
    color: var(--accent-strong);
    text-decoration-color: var(--accent-strong);
  }
  .src-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
