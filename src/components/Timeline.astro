---
import { EVENTS, pick } from '../data/initiative';
import type { Locale } from '../i18n';

interface Props {
  readonly locale: Locale;
}

const { locale } = Astro.props;
---

<ol class="timeline-list" role="list">
  {EVENTS.map((event) => (
    <li class="timeline-item" id={`event-${event.id}`}>
      <div class="timeline-header">
        <time class="timeline-dates mono">{pick(event.dates, locale)}</time>
        <span class="timeline-name">{pick(event.name, locale)}</span>
      </div>
      <p class="timeline-location mono">{pick(event.location, locale)}</p>
      <p class="timeline-summary">{pick(event.summary, locale)}</p>
    </li>
  ))}
</ol>

<style>
  .timeline-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--hairline-strong);
  }
  .timeline-item {
    padding-block: var(--space-m);
    border-bottom: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .timeline-item:last-child {
    border-bottom: none;
  }
  .timeline-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-s);
  }
  .timeline-dates {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .timeline-name {
    font-size: var(--step-0);
    font-weight: 620;
    color: var(--text-strong);
    letter-spacing: -0.006em;
    line-height: 1.3;
  }
  .timeline-location {
    margin: 0;
    font-size: var(--step--2);
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .timeline-summary {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text);
    line-height: 1.55;
    max-width: var(--measure);
  }
</style>
