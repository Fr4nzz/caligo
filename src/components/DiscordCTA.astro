---
/**
 * DiscordCTA — bilingual, dual-state Discord invite control.
 *
 * Reads `discordInviteUrl` from `src/config/site.ts` (nullable, driven by
 * the PUBLIC_CALIGO_DISCORD_URL env var). Renders:
 *
 *   Active state (valid https:// URL) — an external <a> link with
 *   target=_blank + rel=noopener + external-note. Localised strings come
 *   from `t.participate.discord.active`.
 *
 *   Pending state (null / empty / invalid / expired) — a disabled <button>
 *   with no href, no click handler, aria-disabled + disabled attributes,
 *   and the localised pending copy from `t.participate.discord.pending`.
 *
 * The community heading + body are shown in both states so the section
 * always reads as an invitation. Email remains the primary route via
 * ParticipatePage's own contact block.
 *
 * ─── Icon slot ─────────────────────────────────────────────────────────
 * The `.discord-icon` <span> below reserves a clean 1em × 1em glyph slot
 * so the community mark can be swapped in without touching structure or
 * CSS layout. Contract for this slot:
 *
 *   - DO NOT draw an approximate Discord logo manually.
 *   - DO NOT use an emoji fallback.
 *   - EITHER vendor the official SVG from Discord's brand assets page
 *     (https://discord.com/branding) with a LICENSE.md documenting the
 *     source + terms, OR leave the slot empty.
 *
 * The slot is `aria-hidden="true"` so screen readers still hear the
 * button/link label from `d.active.button` / `d.pending.button` and are
 * not made to interpret decorative geometry.
 */
import { getDict, type Locale } from '../i18n';
import { discordInviteUrl } from '../config/site.ts';

interface Props {
  readonly locale: Locale;
  readonly class?: string;
}

const { locale, class: className = '' } = Astro.props;
const t = getDict(locale);
const d = t.participate.discord;

const isActive = discordInviteUrl !== null;
---

<section
  class:list={['discord-cta', className]}
  aria-labelledby="discord-heading"
  data-discord-state={isActive ? 'active' : 'pending'}
>
  <h2 id="discord-heading" class="discord-heading">{d.heading}</h2>
  <p class="discord-body">{d.body}</p>

  {isActive ? (
    <p class="discord-action">
      <a
        class="btn discord-link"
        href={discordInviteUrl}
        target="_blank"
        rel="noopener noreferrer external"
        aria-label={d.active.ariaLabel}
      >
        <svg
          class="discord-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path fill="currentColor" d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.6987.7719 1.3634 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
        </svg>
        <span class="discord-btn-label">{d.active.button}</span>
      </a>
      <span class="discord-note mono">{d.active.externalNote}</span>
    </p>
  ) : (
    <p class="discord-action">
      <button
        class="btn discord-link is-disabled"
        type="button"
        disabled
        aria-disabled="true"
        aria-label={d.pending.ariaLabel}
      >
        <svg
          class="discord-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path fill="currentColor" d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.6987.7719 1.3634 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
        </svg>
        <span class="discord-btn-label">{d.pending.button}</span>
      </button>
      <span class="discord-note mono">{d.pending.note}</span>
    </p>
  )}
</section>

<style>
  .discord-cta {
    padding: var(--space-l);
    background: var(--bg-inset);
    border: 1px solid var(--hairline);
    border-left-width: 2px;
    border-left-color: var(--accent);
    border-radius: var(--radius);
  }
  .discord-heading {
    margin: 0 0 var(--space-s);
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    letter-spacing: -0.008em;
    color: var(--text-strong);
  }
  .discord-body {
    margin: 0 0 var(--space-m);
    color: var(--text);
    max-width: var(--measure);
    line-height: 1.55;
  }
  .discord-action {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
  }
  /*
    Official Discord SVG mark, rendered inline so it inherits currentColor
    from the surrounding link/button. Vendored from Simple Icons (see
    public/media/brand/vendors/LICENSE.md); aria-hidden so the accessible
    name comes from the link text ("Join the Caligo Discord" / "Unirse al
    Discord de Caligo") — never from decorative glyph metadata.
  */
  .discord-icon {
    display: inline-block;
    flex: 0 0 auto;
    width: 1.15em;
    height: 1.15em;
    margin-inline-end: 0.5em;
    vertical-align: -0.15em;
    fill: currentColor;
  }
  .discord-btn-label {
    display: inline-block;
    vertical-align: baseline;
  }
  .discord-link {
    display: inline-flex;
    align-items: center;
  }
  .discord-link.is-disabled,
  .discord-link[disabled] {
    cursor: not-allowed;
    opacity: 0.55;
    background: var(--bg-panel);
    color: var(--text-muted);
    border-color: var(--hairline-strong);
    box-shadow: none;
  }
  .discord-note {
    font-size: var(--step--2);
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
</style>
