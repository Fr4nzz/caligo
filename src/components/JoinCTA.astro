---
/**
 * JoinCTA — registration form CTA, two states.
 *
 * variant="full"    Primary block for /participate#join. Shows h2, body text,
 *                   a primary link-button to LINKS.joinForm, and three small-
 *                   print lines (new-tab note, privacy note, form-name note).
 *
 * variant="compact" Secondary inline link used on Home (H6 closing section)
 *                   and in the Footer, pointing to the localized
 *                   /participate/#join anchor.
 *
 * ─── i18n ──────────────────────────────────────────────────────────────────
 * Consumes the join.* keys from src/i18n (title, body, cta, newTabNote,
 * privacyNote, formNameNote, ctaSecondary), fully typed via Dict.
 */
import { getDict, localePath, type Locale } from '../i18n';
import { LINKS } from '../data/content';

interface Props {
  readonly variant: 'full' | 'compact';
  readonly locale: Locale;
  readonly class?: string;
}

const { variant, locale, class: className = '' } = Astro.props;
const t = getDict(locale);
const j = t.join;

const participateUrl = `${localePath(locale, '/participate')}#join`;
---

{variant === 'full' ? (
  <section
    id="join"
    class:list={['join-cta', className]}
    aria-labelledby="join-heading"
  >
    <h2 id="join-heading" class="join-title">{j.title}</h2>
    <p class="join-body">{j.body}</p>
    <p class="join-action">
      <a
        class="btn btn--primary join-btn"
        href={LINKS.joinForm}
        target="_blank"
        rel="noopener noreferrer"
      >
        {j.cta}
      </a>
    </p>
    <div class="join-small-print">
      <p class="join-note mono">{j.newTabNote}</p>
      <p class="join-note mono">{j.privacyNote}</p>
      <p class="join-note mono">{j.formNameNote}</p>
    </div>
  </section>
) : (
  <p class:list={['join-compact', className]}>
    <a class="join-compact-link" href={participateUrl}>
      {j.ctaSecondary}
    </a>
  </p>
)}

<style>
  /* ── Full variant ──────────────────────────────────────────────────────── */
  .join-cta {
    padding: var(--space-l);
    background: var(--bg-inset);
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius);
  }
  .join-title {
    margin: 0 0 var(--space-s);
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 560;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--text-strong);
  }
  .join-body {
    margin: 0 0 var(--space-m);
    color: var(--text);
    max-width: var(--measure);
    line-height: 1.55;
  }
  .join-action {
    margin: 0 0 var(--space-m);
  }
  /* Ensure the primary CTA meets the 44 px touch-target floor. */
  .join-btn {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .join-small-print {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .join-note {
    margin: 0;
    font-size: var(--step--2);
    color: var(--text-faint);
    letter-spacing: 0.02em;
    line-height: 1.45;
  }

  /* ── Compact variant ───────────────────────────────────────────────────── */
  .join-compact {
    margin: var(--space-s) 0 0;
  }
  .join-compact-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--step--1);
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
    text-decoration-color: color-mix(in oklab, var(--accent) 35%, transparent);
    transition:
      color var(--transition),
      text-decoration-color var(--transition);
    /* 44 px touch target — pad block so the tap zone meets WCAG 2.5.5. */
    min-height: 44px;
    padding-block: calc((44px - 1.2em) / 2);
  }
  .join-compact-link:hover {
    color: var(--accent-strong);
    text-decoration-color: var(--accent-strong);
  }
  .join-compact-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
    text-decoration: none;
  }
</style>
