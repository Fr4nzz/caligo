---
/*
  Página de compatibilidad. La URL /capacity/ se mantiene por retrocompatibilidad,
  pero el directorio de capacidades no se publica en la primera versión
  (informe §1: se retiene hasta que exista consentimiento institucional y
  un registro reproducible de instalaciones). Redirige a Acerca de Caligo
  para el estado actual de la iniciativa.
*/
import Base from '../../layouts/Base.astro';
import { getDict, localePath } from '../../i18n';

const locale = 'es' as const;
const t = getDict(locale);
const c = t.compat;
---

<Base
  locale={locale}
  title={`${c.heading} | Caligo`}
  description={c.body}
  page="/capacity"
  noindex
>
  <section class="container-narrow compat-page">
    <p class="eyebrow">Compat</p>
    <h1>{c.heading}</h1>
    <p class="lead">{c.body}</p>
    <p class="compat-cta">
      <a class="btn" href={localePath(locale, '/network')}>{t.nav.network}</a>
    </p>
  </section>
</Base>

<style>
  .compat-page {
    padding-block: var(--space-xl);
  }
  .compat-page h1 {
    margin-top: 0.6rem;
    max-width: 22ch;
  }
  .compat-page .lead {
    margin-top: var(--space-s);
    max-width: 56ch;
    color: var(--text-muted);
  }
  .compat-cta {
    margin-top: var(--space-l);
  }
</style>
