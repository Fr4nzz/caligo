---
/*
  Compat page. The previous /capacity/ URL is retained so any existing
  inbound link resolves, but the capacity directory is not published in
  the first release (brief §1: withheld until institutional consent and
  a reproducible facility record exist). Point visitors to About for the
  current initiative status.
*/
import Base from '../../layouts/Base.astro';
import { getDict, localePath } from '../../i18n';

const locale = 'en' as const;
const t = getDict(locale);
const c = t.compat;
---

<Base
  locale={locale}
  title={`${c.heading} | Caligo`}
  description={c.body}
  page="/capacity"
  noindex
>
  <section class="container-narrow compat-page">
    <p class="eyebrow">Compat</p>
    <h1>{c.heading}</h1>
    <p class="lead">{c.body}</p>
    <p class="compat-cta">
      <a class="btn" href={localePath(locale, '/network')}>{t.nav.network}</a>
    </p>
  </section>
</Base>

<style>
  .compat-page {
    padding-block: var(--space-xl);
  }
  .compat-page h1 {
    margin-top: 0.6rem;
    max-width: 22ch;
  }
  .compat-page .lead {
    margin-top: var(--space-s);
    max-width: 56ch;
    color: var(--text-muted);
  }
  .compat-cta {
    margin-top: var(--space-l);
  }
</style>
